---
import Layout from '../../../layouts/Layout.astro';
import { VS_PAGES, getVsPage } from '../../../data/vsPages';
import { SITE_URL, BOOKING_URL } from '../../../config';
import { localizedPath } from '../../../i18n';

export function getStaticPaths() {
  return VS_PAGES.map(v => ({ params: { slug: v.slug } }));
}

const locale = 'en' as const;
const { slug } = Astro.params;
const page = getVsPage(slug!);
if (!page) return Astro.redirect('/en/');

const copy = page.content[locale];
const canonical = new URL(localizedPath(`/vs/${page.slug}`, locale), SITE_URL).href;
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: copy.h1,
  description: page.descriptions[locale],
  author: { '@type': 'Organization', name: 'Clicks Strategic Ecosystems' },
  publisher: { '@type': 'Organization', name: 'Clicks Strategic Ecosystems' },
  mainEntityOfPage: canonical,
  inLanguage: locale,
};
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/en/', SITE_URL).href },
    { '@type': 'ListItem', position: 2, name: 'Comparisons', item: new URL('/en/vs', SITE_URL).href },
    { '@type': 'ListItem', position: 3, name: copy.h1, item: canonical },
  ],
};
---

<Layout locale={locale} title={page.titles[locale]} description={page.descriptions[locale]}>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <article class="inner-page vs-page">
    <header class="vs-hero section">
      <div class="container">
        <h1 class="vs-hero__title">{copy.h1}</h1>
        <p class="vs-hero__intro">{copy.intro}</p>
      </div>
    </header>
    <div class="container vs-body">
      {copy.sections.map(s => (
        <section class="vs-section">
          <h2 class="vs-section__heading">{s.heading}</h2>
          <p class="vs-section__body">{s.body}</p>
        </section>
      ))}
      <blockquote class="vs-verdict">
        <p>{copy.verdict}</p>
      </blockquote>
      <div class="vs-cta">
        <a class="btn btn-primary" href={BOOKING_URL}>{copy.cta}</a>
      </div>
    </div>
  </article>
</Layout>

<style>
  .vs-hero { background: var(--color-surface-muted); border-block-end: 1px solid var(--color-divider); padding-block: var(--space-8) var(--space-7); }
  .vs-hero__title { font-size: clamp(var(--text-2xl), 5vw, var(--text-4xl)); font-weight: var(--font-weight-bold); letter-spacing: -0.03em; line-height: 1.15; margin-block-end: var(--space-5); text-wrap: balance; }
  .vs-hero__intro { font-size: var(--text-lg); line-height: 1.6; color: var(--color-text-secondary); max-width: 48ch; }
  .vs-body { padding-block: var(--space-8); max-width: var(--content-narrow); margin-inline: auto; }
  .vs-section { margin-block-end: var(--space-7); padding-block-start: var(--space-6); border-block-start: 1px solid var(--color-divider); }
  .vs-section:first-child { border-block-start: none; padding-block-start: 0; }
  .vs-section__heading { font-size: var(--text-xl); font-weight: var(--font-weight-bold); margin-block-end: var(--space-3); }
  .vs-section__body { font-size: var(--text-base); line-height: var(--line-height-relaxed); color: var(--color-text-secondary); }
  .vs-verdict { margin-block: var(--space-8); padding: var(--space-5) var(--space-6); background: var(--color-brand-subtle, color-mix(in srgb, var(--color-brand) 8%, transparent)); border-inline-start: 4px solid var(--color-brand); border-radius: var(--radius-md); font-size: var(--text-lg); font-weight: var(--font-weight-medium); line-height: 1.5; color: var(--color-text-primary); }
  .vs-verdict p { margin: 0; }
  .vs-cta { margin-block-start: var(--space-7); padding-block-start: var(--space-7); border-block-start: 1px solid var(--color-divider); }
</style>
