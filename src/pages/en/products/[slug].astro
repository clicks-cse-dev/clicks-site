---
import ProductDetailPage from '../../../components/ProductDetailPage.astro';
import { getProductOffers, getProductPage } from '../../../data/productPages';
import { SITE_URL, COMPANY_NAME } from '../../../config';
import { localizedPath } from '../../../i18n';

export function getStaticPaths() {
  return getProductOffers().map((product) => ({ params: { slug: product.slug } }));
}

const locale = 'en' as const;
const slug = Astro.params.slug!;
const product = getProductPage(slug)!;

const canonical = new URL(localizedPath(`/products/${slug}`, locale), SITE_URL).href;
const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: product.titles[locale],
  description: product.descriptions[locale],
  provider: { '@type': 'Organization', name: COMPANY_NAME, url: SITE_URL },
  areaServed: 'IL',
  url: canonical,
};
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: locale === 'he' ? 'דף הבית' : 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: locale === 'he' ? 'פתרונות' : 'Solutions', item: new URL(localizedPath('/solutions', locale), SITE_URL).href },
    { '@type': 'ListItem', position: 3, name: product.titles[locale], item: canonical },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
<ProductDetailPage locale={locale} product={product} />
