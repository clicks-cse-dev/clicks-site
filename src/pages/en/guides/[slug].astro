---
import Layout from '../../../layouts/Layout.astro';
import { GUIDE_PAGES, getGuide } from '../../../data/guidePages';
import { SITE_URL, BOOKING_URL } from '../../../config';
import { localizedPath } from '../../../i18n';

export function getStaticPaths() {
  return GUIDE_PAGES.map(g => ({ params: { slug: g.slug } }));
}

const locale = 'en' as const;
const { slug } = Astro.params;
const guide = getGuide(slug!);
if (!guide) return Astro.redirect('/en/');

const copy = guide.content[locale];
const canonical = new URL(localizedPath(`/guides/${guide.slug}`, locale), SITE_URL).href;
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: copy.h1,
  description: guide.descriptions[locale],
  datePublished: guide.publishDate,
  author: { '@type': 'Organization', name: 'Clicks Strategic Ecosystems' },
  publisher: { '@type': 'Organization', name: 'Clicks Strategic Ecosystems' },
  mainEntityOfPage: canonical,
  inLanguage: locale,
};
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/en/', SITE_URL).href },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: new URL('/en/guides', SITE_URL).href },
    { '@type': 'ListItem', position: 3, name: copy.h1, item: canonical },
  ],
};
---

<Layout locale={locale} title={guide.titles[locale]} description={guide.descriptions[locale]}>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <article class="inner-page guide-page">
    <header class="guide-hero section">
      <div class="container">
        <h1 class="guide-hero__title">{copy.h1}</h1>
        <p class="guide-hero__intro">{copy.intro}</p>
      </div>
    </header>
    <div class="container guide-body">
      {copy.sections.map(s => (
        <section class="guide-section">
          <h2 class="guide-section__heading">{s.heading}</h2>
          <p class="guide-section__body">{s.body}</p>
        </section>
      ))}
      <div class="guide-cta">
        <a class="btn btn-primary" href={BOOKING_URL}>{copy.cta}</a>
      </div>
    </div>
  </article>
</Layout>

<style>
  .guide-hero { background: var(--color-surface-muted); border-block-end: 1px solid var(--color-divider); padding-block: var(--space-8) var(--space-7); }
  .guide-hero__title { font-size: clamp(var(--text-2xl), 5vw, var(--text-4xl)); font-weight: var(--font-weight-bold); letter-spacing: -0.03em; line-height: 1.15; margin-block-end: var(--space-5); text-wrap: balance; }
  .guide-hero__intro { font-size: var(--text-lg); line-height: 1.6; color: var(--color-text-secondary); max-width: 48ch; }
  .guide-body { padding-block: var(--space-8); max-width: var(--content-narrow); margin-inline: auto; }
  .guide-section { margin-block-end: var(--space-7); padding-block-start: var(--space-6); border-block-start: 1px solid var(--color-divider); }
  .guide-section:first-child { border-block-start: none; padding-block-start: 0; }
  .guide-section__heading { font-size: var(--text-xl); font-weight: var(--font-weight-bold); margin-block-end: var(--space-3); }
  .guide-section__body { font-size: var(--text-base); line-height: var(--line-height-relaxed); color: var(--color-text-secondary); }
  .guide-cta { margin-block-start: var(--space-8); padding-block-start: var(--space-7); border-block-start: 1px solid var(--color-divider); }
</style>
