---
import Layout from '../../layouts/Layout.astro';
import { EMAIL_SAPIR, VAT, DOMAIN } from '../../config';

const locale = 'en' as const;

const t = {
  title: 'Privacy policy',
  description: 'Privacy policy for clickcse.com — Clicks Strategic Ecosystems.',
  h1: 'Privacy policy',
  updated: 'Last updated: June 2026',
  sections: [
    {
      h: 'Who we are',
      p: `This website (${DOMAIN}) is operated by Clicks Strategic Ecosystems (licensed dealer no. ${VAT}).`,
    },
    {
      h: 'What we collect',
      p: 'When you submit an inquiry through the site, your details are sent to us by email — they are not stored on the website server.',
    },
    {
      h: 'How we use data',
      p: 'We use details you submit only to respond, schedule a call or provide professional services — not sold to third parties.',
    },
    {
      h: 'Your rights',
      p: 'You may request access, correction or deletion of personal data you provided — via the email below.',
    },
    {
      h: 'Contact',
      p: 'Privacy questions:',
    },
  ],
} as const;
---

<Layout locale={locale} title={t.title} description={t.description}>
  <article class="section page legal">
    <div class="container page__narrow">
      <h1 class="page__title">{t.h1}</h1>
      <p class="legal__meta">{t.updated}</p>
      {t.sections.map((s) => (
        <section class="legal__block">
          <h2>{s.h}</h2>
          <p>{s.p}</p>
        </section>
      ))}
      <p><a href={`mailto:${EMAIL_SAPIR}`}>{EMAIL_SAPIR}</a></p>
    </div>
  </article>
</Layout>

<style>
  .page__narrow {
    max-width: var(--content-narrow, 720px);
  }
  .page__title {
    margin: 0 0 var(--space-3);
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-bold);
  }
  .legal__meta {
    margin: 0 0 var(--space-8);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
  .legal__block {
    margin-block-end: var(--space-6);
  }
  .legal__block h2 {
    margin: 0 0 var(--space-3);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
  }
  .legal__block p {
    margin: 0;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }
</style>
