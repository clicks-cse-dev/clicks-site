---
import Layout from '../../../layouts/Layout.astro';
import BlogArticle from '../../../components/blog/BlogArticle.astro';
import { BLOG_POSTS, getBlogPost, getBlogPostLocale } from '../../../data/blogPosts';
import { SITE_URL, COMPANY_NAME } from '../../../config';
import { localizedPath } from '../../../i18n';

export function getStaticPaths() {
  return BLOG_POSTS.map((post) => ({ params: { slug: post.slug } }));
}

const locale = 'en' as const;
const { slug } = Astro.params;
const post = getBlogPost(slug!);
if (!post) return Astro.redirect(localizedPath('/cases', locale));

const copy = getBlogPostLocale(post, locale);
const canonical = new URL(localizedPath(`/cases/${post.slug}`, locale), SITE_URL).href;
const casesLabel = 'Client stories';
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: copy.h1,
  description: copy.description,
  datePublished: post.publishDate,
  author: { '@type': 'Organization', name: COMPANY_NAME },
  publisher: { '@type': 'Organization', name: COMPANY_NAME },
  mainEntityOfPage: canonical,
  inLanguage: locale,
};
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/en/', SITE_URL).href },
    {
      '@type': 'ListItem',
      position: 2,
      name: casesLabel,
      item: new URL(localizedPath('/cases', locale), SITE_URL).href,
    },
    { '@type': 'ListItem', position: 3, name: copy.h1, item: canonical },
  ],
};
---

<Layout locale={locale} title={copy.title} description={copy.description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <BlogArticle locale={locale} post={post} />
</Layout>
