---
import SectorDetailPage from '../../components/SectorDetailPage.astro';
import { SECTOR_PAGE_DATA, getSectorPage } from '../../data/sectorPages';
import { SITE_URL, COMPANY_NAME } from '../../config';
import { localizedPath } from '../../i18n';

export function getStaticPaths() {
  return SECTOR_PAGE_DATA.map((sector) => ({ params: { slug: sector.slug } }));
}

const locale = 'he' as const;
const slug = Astro.params.slug!;
const sector = getSectorPage(slug)!;

const canonical = new URL(localizedPath(`/sectors/${slug}`, locale), SITE_URL).href;
const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: sector.titles[locale],
  description: sector.descriptions[locale],
  provider: { '@type': 'Organization', name: COMPANY_NAME, url: SITE_URL },
  areaServed: 'IL',
  url: canonical,
};
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: locale === 'he' ? 'דף הבית' : 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: locale === 'he' ? 'פתרונות' : 'Solutions', item: new URL(localizedPath('/solutions', locale), SITE_URL).href },
    { '@type': 'ListItem', position: 3, name: sector.titles[locale], item: canonical },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
<SectorDetailPage locale={locale} sector={sector} />
