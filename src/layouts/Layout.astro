---
/**
 * Base layout for every page.
 * Sets <html lang dir> from locale (rtl for he), loads fonts + global tokens,
 * renders Header + <slot/> + Footer. (PRD §1, §9, §10.)
 */
import { getImage } from 'astro:assets';
import '../styles/design-system.css';
import '../styles/inner-pages.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Mixpanel from '../components/analytics/Mixpanel.astro';
import JsonLd from '../components/JsonLd.astro';
import logo from '../assets/clicks-logo.png';
import { dir, canonicalPathFromUrl, localizedPath, LOCALES, type Locale } from '../i18n';
import { COMPANY_NAME, SITE_URL } from '../config';
import { buildOrganizationJsonLd } from '../lib/structuredData';

const FONTS_URL =
  'https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800&family=Noto+Sans+Hebrew:wght@400;500;600;700;800&display=swap';

const headerLogo = await getImage({ src: logo, width: 420, format: 'webp' });

type JsonLdSchema = Record<string, unknown>;

interface Props {
  locale: Locale;
  title: string;
  description?: string;
  jsonLd?: JsonLdSchema | JsonLdSchema[];
}

const { locale, title, description = '', jsonLd } = Astro.props;
const htmlDir = dir(locale);
const fullTitle = title ? `${title} · ${COMPANY_NAME}` : COMPANY_NAME;
const canonical = new URL(Astro.url.pathname, SITE_URL).href;
const canonicalPath = canonicalPathFromUrl(Astro.url);
const ogImage = new URL('/og.png', SITE_URL).href;
const hreflangLinks = LOCALES.map((loc) => ({
  locale: loc,
  href: new URL(localizedPath(canonicalPath, loc), SITE_URL).href,
}));

const structuredData = [
  buildOrganizationJsonLd(locale),
  ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []),
];
---

<!doctype html>
<html lang={locale} dir={htmlDir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonical} />
    {hreflangLinks.map((alt) => (
      <link rel="alternate" hreflang={alt.locale} href={alt.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={hreflangLinks.find((a) => a.locale === 'he')!.href} />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}

    <!-- SEO / OpenGraph -->
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={COMPANY_NAME} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts: non-render-blocking load (LCP); metric-adjusted fallbacks in design-system.css (CLS) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href={FONTS_URL} />
    <link rel="stylesheet" href={FONTS_URL} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={FONTS_URL} /></noscript>

    <!-- LCP preload: header logo is the above-fold image on homepage and product pages -->
    <link rel="preload" as="image" href={headerLogo.src} type="image/webp" fetchpriority="high" />

    <JsonLd schemas={structuredData} />
  </head>
  <body>
    <a class="skip-link" href="#main">{locale === 'he' ? 'דלג לתוכן' : 'Skip to content'}</a>
    <Header locale={locale} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
    <Mixpanel />
  </body>
</html>
