---
/**
 * Base layout for every page.
 * Sets <html lang dir> from locale (rtl for he), loads fonts + global tokens,
 * renders Header + <slot/> + Footer. (PRD §1, §9, §10.)
 */
import '../styles/design-system.css';
import '../styles/inner-pages.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Mixpanel from '../components/analytics/Mixpanel.astro';
import { dir, canonicalPathFromUrl, localizedPath, LOCALES, type Locale } from '../i18n';
import { COMPANY_NAME, GOOGLE_SITE_VERIFICATION, SITE_URL } from '../config';

interface Props {
  locale: Locale;
  title: string;
  description?: string;
}

const { locale, title, description = '' } = Astro.props;
const htmlDir = dir(locale);
const fullTitle = title ? `${title} · ${COMPANY_NAME}` : COMPANY_NAME;
const canonical = new URL(Astro.url.pathname, SITE_URL).href;
const canonicalPath = canonicalPathFromUrl(Astro.url);
const ogImage = new URL('/og.png', SITE_URL).href;
const hreflangLinks = LOCALES.map((loc) => ({
  locale: loc,
  href: new URL(localizedPath(canonicalPath, loc), SITE_URL).href,
}));

// Organization structured data (JSON-LD) for search engine rich results
const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Clicks Strategic Ecosystems",
  "url": "https://clickcse.com",
  "logo": "https://clickcse.com/og.png",
  "description": "ייעוץ, אפיון ובנייה של מערכות הפעלה על monday.com לגופים ציבוריים, רשויות, מלכ\"רים וחברות טכנולוגיה בישראל.",
  "areaServed": "IL",
  "foundingDate": "2024",
  "serviceType": ["monday.com consulting", "process automation", "CRM implementation", "GIS integration"],
  "knowsLanguage": ["he", "en"],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "availableLanguage": ["Hebrew", "English"]
  },
  "sameAs": [
    "https://monday.com/gotopartners/directory/"
  ]
};
---

<!doctype html>
<html lang={locale} dir={htmlDir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonical} />
    {hreflangLinks.map((alt) => (
      <link rel="alternate" hreflang={alt.locale} href={alt.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={hreflangLinks.find((a) => a.locale === 'he')!.href} />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    {GOOGLE_SITE_VERIFICATION && (
      <meta name="google-site-verification" content={GOOGLE_SITE_VERIFICATION} />
    )}

    <!-- SEO / OpenGraph -->
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={COMPANY_NAME} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts: Figtree (UI + display) + Noto Sans Hebrew (RTL fallback) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800&family=Noto+Sans+Hebrew:wght@400;500;600;700;800&display=swap"
    />

    <!-- LCP preload: hint browser to fetch OG/hero image early (Core Web Vitals) -->
    <link rel="preload" as="image" href={ogImage} fetchpriority="high" />

    <!-- Organization structured data for search engine rich results -->
    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
  </head>
  <body>
    <a class="skip-link" href="#main">{locale === 'he' ? 'דלג לתוכן' : 'Skip to content'}</a>
    <Header locale={locale} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
    <Mixpanel />
  </body>
</html>
