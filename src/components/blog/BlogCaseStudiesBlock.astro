---
import { localizedPath, type Locale } from '../../i18n';
import type { BlogPost } from '../../data/blogPosts';

interface Props {
  locale: Locale;
  posts: BlogPost[];
}

const { locale, posts } = Astro.props;
if (posts.length === 0) return;

const ui = {
  he: {
    title: 'בפרויקטים מהשטח',
    read: 'לקריאת הסיפור',
  },
  en: {
    title: 'From the field',
    read: 'Read the story',
  },
} as const;

const t = ui[locale];
---

<section class="blog-cases-block inner-section" aria-labelledby="blog-cases-block-title">
  <header class="inner-section__head">
    <h2 id="blog-cases-block-title" class="inner-section__title">{t.title}</h2>
  </header>
  <ul class="blog-cases-block__list" role="list">
    {
      posts.map((post) => (
        <li class="blog-cases-block__item card">
          <p class="blog-cases-block__sector">{post.sectorLabel[locale]}</p>
          <h3 class="blog-cases-block__h3">{post.h1[locale]}</h3>
          <p class="blog-cases-block__lead">{post.lead[locale]}</p>
          <a class="btn btn-secondary" href={localizedPath(`/cases/${post.slug}`, locale)}>
            {t.read}
          </a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .blog-cases-block__list {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .blog-cases-block__item {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .blog-cases-block__sector {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-accent);
  }

  .blog-cases-block__h3 {
    margin: 0;
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-snug);
    text-align: start;
  }

  .blog-cases-block__lead {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    text-align: start;
  }
</style>
