---
import CaseStudyOfferLines from './CaseStudyOfferLines.astro';
import { localizedPath, type Locale } from '../../i18n';
import { BOOKING_URL } from '../../config';
import { getBlogPostLocale, type BlogPost } from '../../data/blogPosts';
import { getCaseStudyOfferLists } from '../../data/caseStudyOffers';
import { getProductPage, offerPagePath } from '../../data/productPages';

interface Props {
  locale: Locale;
  post: BlogPost;
}

const { locale, post } = Astro.props;
const t = getBlogPostLocale(post, locale);
const offers = getCaseStudyOfferLists(post, locale);
const casesIndexHref = localizedPath('/cases', locale);

const ui = {
  he: {
    eyebrow: 'סיפור לקוח',
    challenge: 'האתגר',
    approach: 'הגישה שלנו',
    built: 'מה בנינו',
    inPractice: 'איך זה עובד בפועל',
    outcomes: 'תוצאות',
    deliverablesTitle: 'תוצרים והמוצרים שמימשו אותם',
    metricsTitle: 'בקצרה',
    book: 'לקביעת שיחת ייעוץ',
    back: 'סיפורי לקוח',
    explore: 'לדף המוצר',
    ctaTitle: 'רוצים לבנות משהו דומה?',
    ctaText: 'שיחה קצרה: מיפוי המצב, דוגמה מהשטח, ותוכנית הטמעה ריאלית.',
  },
  en: {
    eyebrow: 'Case study',
    challenge: 'The challenge',
    approach: 'Our approach',
    built: 'What we built',
    inPractice: 'How it works in practice',
    outcomes: 'Outcomes',
    deliverablesTitle: 'Deliverables and the products behind them',
    metricsTitle: 'At a glance',
    book: 'Book a discovery call',
    back: 'Client stories',
    explore: 'View page',
    ctaTitle: 'Want to build something similar?',
    ctaText: 'A short call: map your setup, see a relevant example, and a realistic rollout plan.',
  },
} as const;

const labels = ui[locale];

const deliverableLinks = post.refs.deliverables.map((d) => {
  const product = getProductPage(d.productSlug);
  return {
    label: d.label[locale],
    href: localizedPath(offerPagePath(d.productSlug), locale),
    productName: product?.titles[locale] ?? d.productSlug,
  };
});

const primaryProduct = post.refs.primaryProductSlugs[0]
  ? getProductPage(post.refs.primaryProductSlugs[0])
  : undefined;
const primaryProductHref = primaryProduct
  ? localizedPath(offerPagePath(post.refs.primaryProductSlugs[0]), locale)
  : null;
---

<article class="case-page">
  <header class="case-hero section">
    <div class="container case-hero__inner">
      <nav class="case-breadcrumb" aria-label={locale === 'he' ? 'מיקום בעמוד' : 'Breadcrumb'}>
        <a href={casesIndexHref}>{labels.back}</a>
        <span class="case-breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">{t.project}</span>
      </nav>

      <p class="case-hero__tag">{labels.eyebrow}</p>
      <p class="case-hero__meta">
        <span class="case-hero__sector">{t.sectorLabel}</span>
        <span class="case-hero__meta-sep" aria-hidden="true">·</span>
        <span>{t.project}</span>
      </p>
      <h1 class="case-hero__title">{t.h1}</h1>
      <p class="case-hero__lead">{t.lead}</p>

      {
        t.metrics.length > 0 && (
          <section class="case-metrics" aria-labelledby="case-metrics-title">
            <h2 id="case-metrics-title" class="case-metrics__title">{labels.metricsTitle}</h2>
            <dl class="case-metrics__grid">
              {
                t.metrics.map((metric) => (
                  <div class="case-metrics__item">
                    <dt>{metric.label}</dt>
                    <dd>{metric.value}</dd>
                    {metric.delta && <p class="case-metrics__hint">{metric.delta}</p>}
                  </div>
                ))
              }
            </dl>
          </section>
        )
      }

      <p class="case-bridge">{t.sections.bridge}</p>
      <CaseStudyOfferLines locale={locale} {...offers} variant="inline" />
    </div>
  </header>

  <section class="section case-story" aria-labelledby="challenge-title">
    <div class="container">
      <div class="case-story__duo">
        <article class="case-story__panel">
          <h2 id="challenge-title" class="case-story__label">{labels.challenge}</h2>
          <p>{t.sections.challenge}</p>
        </article>
        <article class="case-story__panel">
          <h2 class="case-story__label">{labels.approach}</h2>
          <p>{t.sections.approach}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section case-built" aria-labelledby="built-title">
    <div class="container">
      <h2 id="built-title" class="case-section-title">{labels.built}</h2>
      <ul class="case-built__grid" role="list">
        {
          t.sections.built.map((item, i) => (
            <li class="case-built__item">
              <span class="case-built__num" aria-hidden="true">{i + 1}</span>
              <p>{item}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section case-deliverables" aria-labelledby="deliverables-title">
    <div class="container">
      <h2 id="deliverables-title" class="case-section-title">{labels.deliverablesTitle}</h2>
      <ul class="case-deliverables__grid" role="list">
        {
          deliverableLinks.map((d) => (
            <li class="case-deliverables__item">
              <p class="case-deliverables__label">{d.label}</p>
              <a href={d.href}>{d.productName}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section case-results" aria-labelledby="practice-title">
    <div class="container">
      <div class="case-results__duo">
        <article class="case-results__panel">
          <h2 id="practice-title" class="case-results__title">{labels.inPractice}</h2>
          <p>{t.sections.inPractice}</p>
        </article>
        <article class="case-results__panel">
          <h2 class="case-results__title">{labels.outcomes}</h2>
          <p>{t.sections.outcomes}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section case-cta" aria-labelledby="case-cta-title">
    <div class="container">
      <div class="case-cta__panel card">
        <h2 id="case-cta-title" class="case-cta__title">{labels.ctaTitle}</h2>
        <p class="case-cta__lead">{labels.ctaText}</p>
        <div class="case-cta__actions">
          <a class="btn btn-primary" href={BOOKING_URL}>{labels.book}</a>
          {
            primaryProductHref && primaryProduct && (
              <a class="btn btn-secondary" href={primaryProductHref}>
                {labels.explore} {primaryProduct.titles[locale]}
              </a>
            )
          }
        </div>
      </div>
    </div>
  </section>
</article>

<style>
  .case-page {
    background: var(--color-bg-mesh);
  }

  /* ---- Hero ---- */
  .case-hero {
    padding-block: var(--space-8) var(--space-7);
    border-block-end: 1px solid var(--color-divider);
    background:
      radial-gradient(ellipse 75% 60% at 100% 0%, var(--color-accent-muted), transparent 58%),
      var(--color-surface);
  }

  .case-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin-block-end: var(--space-6);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .case-breadcrumb a {
    color: var(--color-accent);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
  }

  .case-breadcrumb a:hover {
    color: var(--color-accent-hover);
  }

  .case-breadcrumb__sep {
    opacity: 0.45;
    user-select: none;
  }

  .case-breadcrumb [aria-current='page'] {
    color: var(--color-text-secondary);
    font-weight: var(--font-weight-medium);
  }

  .case-hero__inner {
    max-width: var(--content-max, 960px);
  }

  .case-hero__tag {
    margin: 0;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-accent);
  }

  .case-hero__meta {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .case-hero__sector {
    font-weight: var(--font-weight-semibold);
    color: var(--color-accent);
  }

  .case-hero__meta-sep {
    color: var(--color-text-faint);
  }

  .case-hero__title {
    margin: 0;
    font-size: clamp(var(--text-2xl), 4.2vw, var(--text-4xl));
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.035em;
    line-height: 1.12;
    text-wrap: balance;
    text-align: start;
  }

  .case-hero__lead {
    margin: 0 0 var(--space-6);
    max-width: 42rem;
    font-size: var(--text-lg);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    text-wrap: pretty;
    text-align: start;
  }

  .case-metrics {
    margin-block-end: var(--space-6);
  }

  .case-metrics__title {
    margin: 0 0 var(--space-3);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    text-align: start;
  }

  .case-metrics__grid {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-border);
  }

  @media (min-width: 720px) {
    .case-metrics__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .case-metrics__item {
    margin: 0;
    padding: var(--space-4);
    background: var(--color-surface-raised);
  }

  .case-metrics__item dt {
    margin: 0 0 var(--space-1);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .case-metrics__item dd {
    margin: 0;
    font-size: var(--text-md);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-snug);
    color: var(--color-text);
  }

  .case-metrics__hint {
    margin: var(--space-1) 0 0;
    font-size: var(--text-xs);
    line-height: var(--line-height-normal);
    color: var(--color-text-muted);
  }

  .case-bridge {
    margin: 0 0 var(--space-5);
    max-width: 42rem;
    padding: 0;
    font-size: var(--text-base);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    text-align: start;
    text-wrap: pretty;
    background: none;
    border: none;
    box-shadow: none;
  }

  .case-bridge::before {
    content: '';
    display: block;
    inline-size: 2.5rem;
    block-size: 3px;
    margin-block-end: var(--space-3);
    border-radius: var(--radius-full);
    background: var(--color-accent);
  }

  /* ---- Section titles ---- */
  .case-section-title {
    margin: 0 0 var(--space-6);
    font-size: clamp(var(--text-xl), 3vw, var(--text-2xl));
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.02em;
    text-align: start;
  }

  /* ---- Story duo ---- */
  .case-story__duo {
    display: grid;
    gap: var(--space-4);
  }

  @media (min-width: 720px) {
    .case-story__duo {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .case-story__panel {
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-xs);
  }

  .case-story__label {
    margin: 0 0 var(--space-3);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
    text-align: start;
  }

  .case-story__panel p {
    margin: 0;
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    text-align: start;
  }

  /* ---- Built grid ---- */
  .case-built__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .case-built__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .case-built__item {
    position: relative;
    margin: 0;
    padding: var(--space-5) var(--space-5) var(--space-5) var(--space-6);
    border-radius: var(--radius-lg);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-xs);
  }

  .case-built__num {
    position: absolute;
    inset-block-start: var(--space-4);
    inset-inline-start: var(--space-4);
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-extrabold);
    line-height: 1;
    color: color-mix(in srgb, var(--color-accent) 28%, transparent);
    font-variant-numeric: tabular-nums;
  }

  .case-built__item p {
    margin: 0;
    padding-inline-start: var(--space-6);
    font-size: var(--text-base);
    line-height: var(--line-height-relaxed);
    color: var(--color-text);
    text-align: start;
  }

  /* ---- Deliverables ---- */
  .case-deliverables__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .case-deliverables__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .case-deliverables__item {
    padding: var(--space-5) var(--space-6);
    border-radius: var(--radius-lg);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-block-start: 3px solid var(--color-accent);
    box-shadow: var(--shadow-xs);
  }

  .case-deliverables__label {
    margin: 0 0 var(--space-2);
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-snug);
    color: var(--color-text);
    text-align: start;
  }

  .case-deliverables__item a {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-accent);
    text-decoration: none;
  }

  .case-deliverables__item a:hover {
    text-decoration: underline;
  }

  /* ---- Results duo ---- */
  .case-results__duo {
    display: grid;
    gap: var(--space-4);
  }

  @media (min-width: 720px) {
    .case-results__duo {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .case-results__panel {
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    background: linear-gradient(
      155deg,
      var(--color-surface-raised) 0%,
      color-mix(in srgb, var(--color-accent-muted) 55%, var(--color-surface-raised)) 100%
    );
    border: 1px solid var(--color-border);
  }

  .case-results__title {
    margin: 0 0 var(--space-3);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    text-align: start;
  }

  .case-results__panel p {
    margin: 0;
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    text-align: start;
  }

  /* ---- CTA ---- */
  .case-cta__panel {
    max-width: var(--panel-max-wide, 960px);
    margin-inline: auto;
    padding: var(--space-8) var(--space-7);
    text-align: center;
    background: linear-gradient(
      165deg,
      var(--color-surface-raised) 0%,
      color-mix(in srgb, var(--color-accent-muted) 70%, var(--color-surface-raised)) 100%
    );
    border-color: color-mix(in srgb, var(--color-accent) 25%, var(--color-border));
  }

  .case-cta__title {
    margin: 0 0 var(--space-3);
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.02em;
  }

  .case-cta__lead {
    margin: 0 auto var(--space-6);
    max-width: 36rem;
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
  }

  .case-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }
</style>
