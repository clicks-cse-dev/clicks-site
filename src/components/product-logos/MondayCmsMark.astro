---
/** Bridge mark from MondayCMS CseLogo.tsx — two node clusters linked by a sync arc. */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 200 130"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <line x1="22" y1="65" x2="52" y2="28" stroke="var(--product-brand-line)" stroke-width="3" stroke-linecap="round" />
  <line x1="22" y1="65" x2="52" y2="102" stroke="var(--product-brand-line)" stroke-width="3" stroke-linecap="round" />
  <circle cx="22" cy="65" r="10" fill="var(--product-brand-deep)" />
  <circle cx="52" cy="28" r="6.5" fill="var(--product-brand-node)" />
  <circle cx="52" cy="102" r="6.5" fill="var(--product-brand-node)" />
  <path
    d="M62 65 C82 30, 118 30, 138 65"
    stroke="var(--product-brand-spark)"
    stroke-width="4"
    fill="none"
    stroke-linecap="round"
  />
  <line x1="89" y1="42" x2="89" y2="65" stroke="var(--product-brand-spark)" stroke-width="2.5" stroke-linecap="round" />
  <line x1="111" y1="42" x2="111" y2="65" stroke="var(--product-brand-spark)" stroke-width="2.5" stroke-linecap="round" />
  <line x1="62" y1="65" x2="138" y2="65" stroke="var(--product-brand-spark)" stroke-width="3" stroke-linecap="round" opacity="0.7" />
  <circle cx="62" cy="65" r="4.5" fill="var(--product-brand-spark)" />
  <circle cx="138" cy="65" r="4.5" fill="var(--product-brand-spark)" />
  <line x1="178" y1="65" x2="148" y2="28" stroke="var(--product-brand-line)" stroke-width="3" stroke-linecap="round" />
  <line x1="178" y1="65" x2="148" y2="102" stroke="var(--product-brand-line)" stroke-width="3" stroke-linecap="round" />
  <circle cx="178" cy="65" r="10" fill="var(--product-brand-deep)" />
  <circle cx="148" cy="28" r="6.5" fill="var(--product-brand-node)" />
  <circle cx="148" cy="102" r="6.5" fill="var(--product-brand-node)" />
</svg>
