---
/** Blueprint / process nodes — FlowGram */
interface Props {
  class?: string;
  size?: number;
}
const { class: className = '', size } = Astro.props;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 100 100"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <rect x="12" y="14" width="28" height="22" rx="6" stroke="var(--product-brand-line)" stroke-width="3" />
  <rect x="60" y="14" width="28" height="22" rx="6" stroke="var(--product-brand-line)" stroke-width="3" />
  <rect x="36" y="64" width="28" height="22" rx="6" stroke="var(--product-brand-node)" stroke-width="3" fill="var(--product-accent-soft)" />
  <path d="M40 25h20" stroke="var(--product-brand-spark)" stroke-width="2.5" stroke-linecap="round" />
  <path d="M26 36v12a8 8 0 0 0 8 8h4" stroke="var(--product-brand-deep)" stroke-width="2.5" stroke-linecap="round" />
  <path d="M74 36v12a8 8 0 0 1-8 8h-4" stroke="var(--product-brand-deep)" stroke-width="2.5" stroke-linecap="round" />
  <circle cx="50" cy="52" r="4" fill="var(--product-brand-spark)" />
</svg>
