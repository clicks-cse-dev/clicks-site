---
/** Ready-to-deploy ecosystem tiles */
interface Props {
  class?: string;
  size?: number;
}
const { class: className = '', size } = Astro.props;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 100 100"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <rect x="14" y="14" width="32" height="32" rx="7" stroke="var(--product-brand-node)" stroke-width="3" fill="var(--product-accent-soft)" />
  <rect x="54" y="14" width="32" height="32" rx="7" stroke="var(--product-brand-line)" stroke-width="3" />
  <rect x="14" y="54" width="32" height="32" rx="7" stroke="var(--product-brand-line)" stroke-width="3" />
  <path d="M54 70h32M70 54v32" stroke="var(--product-brand-spark)" stroke-width="3.5" stroke-linecap="round" />
  <circle cx="70" cy="70" r="5" fill="var(--product-brand-spark)" />
</svg>
