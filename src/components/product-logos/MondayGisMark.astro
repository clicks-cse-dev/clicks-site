---
/** Map mark from MondayGIS ClicksMondayGisLogo.tsx */
interface Props {
  class?: string;
  size?: number;
}
const { class: className = '', size } = Astro.props;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 100 100"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <circle cx="50" cy="50" r="40" fill="var(--product-accent-soft)" />
  <circle cx="50" cy="50" r="40" stroke="var(--product-brand-deep)" stroke-width="3.5" fill="none" />
  <line x1="14" y1="50" x2="86" y2="50" stroke="var(--product-brand-line)" stroke-width="2" stroke-linecap="round" opacity="0.9" />
  <line x1="50" y1="14" x2="50" y2="86" stroke="var(--product-brand-line)" stroke-width="2" stroke-linecap="round" opacity="0.9" />
  <line x1="14" y1="34" x2="86" y2="34" stroke="var(--product-brand-pale)" stroke-width="1.5" stroke-linecap="round" opacity="0.75" />
  <line x1="14" y1="66" x2="86" y2="66" stroke="var(--product-brand-pale)" stroke-width="1.5" stroke-linecap="round" opacity="0.75" />
  <line x1="34" y1="14" x2="34" y2="86" stroke="var(--product-brand-pale)" stroke-width="1.5" stroke-linecap="round" opacity="0.75" />
  <line x1="66" y1="14" x2="66" y2="86" stroke="var(--product-brand-pale)" stroke-width="1.5" stroke-linecap="round" opacity="0.75" />
  <path
    d="M32 58 L48 44 L68 52 L62 72 L38 70 Z"
    fill="var(--product-brand-node)"
    fill-opacity="0.35"
    stroke="var(--product-brand-node)"
    stroke-width="2.5"
    stroke-linejoin="round"
  />
  <path
    d="M54 38 C60 38 64 44 64 50 C64 58 54 68 54 68 C54 68 44 58 44 50 C44 44 48 38 54 38Z"
    fill="var(--product-brand-deep)"
  />
  <circle cx="54" cy="48" r="4.5" fill="var(--product-brand-pale)" />
  <circle cx="68" cy="32" r="5" fill="var(--product-brand-spark)" />
  <path d="M68 37 L68 46" stroke="var(--product-brand-spark)" stroke-width="2.5" stroke-linecap="round" />
</svg>
