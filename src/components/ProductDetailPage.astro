---
import Layout from '../layouts/Layout.astro';
import ProductHeroLogo from './product-logos/ProductHeroLogo.astro';
import ProductCardLogo from './product-logos/ProductCardLogo.astro';
import './product-logos/ProductLockup.css';
import { localizedPath, type Locale } from '../i18n';
import { BOOKING_URL } from '../config';
import { getRelatedProducts, offerPagePath, type ProductPageData } from '../data/productPages';
import { getPostsForProduct } from '../data/blogPostRefs';
import BlogCaseStudiesBlock from './blog/BlogCaseStudiesBlock.astro';
import ProductDemo from './product-demos/ProductDemo.astro';
import ReadyDeployDemo from './product-demos/ReadyDeployDemo.astro';

interface Props {
  locale: Locale;
  product: ProductPageData;
}

const { locale, product } = Astro.props;
const related = getRelatedProducts(product.relatedSlugs);
const caseStudies = getPostsForProduct(product.slug, 2);

const isProduct = product.kind === 'product';
const showDemo = ['cms', 'gis', 'crm', 'flowgram', 'tsm', 'ready'].includes(product.logo);

const ui = {
  he: {
    breadcrumbSolutions: 'פתרונות',
    breadcrumbKind: isProduct ? 'מוצרים' : 'שירותים',
    audienceTitle: 'למי זה מתאים',
    problemsTitle: 'מה בדרך כלל לא עובד היום',
    featuresTitle: 'מה מקבלים',
    scenariosTitle: 'דוגמאות מהשטח',
    stepsTitle: 'איך זה עובד אצלנו',
    relatedTitle: 'עובד יחד עם',
    factSheetTitle: 'בקצרה',
    demoTitle: 'ראו איך זה נראה',
    book: 'לקביעת שיחת ייעוץ',
    solutions: 'מפת הפתרונות',
    cases: 'סיפורי לקוח',
    explore: 'לדף המוצר',
    ctaTitle: 'רוצים לראות את זה על התהליך שלכם?',
    ctaText: 'שיחת ייעוץ קצרה: מיפוי המצב, הדגמה רלוונטית, ותוכנית הטמעה ריאלית.',
    homeProducts: 'משפחת המוצרים',
  },
  en: {
    breadcrumbSolutions: 'Solutions',
    breadcrumbKind: isProduct ? 'Products' : 'Services',
    audienceTitle: 'Who it is for',
    problemsTitle: 'What usually breaks today',
    featuresTitle: 'What you get',
    scenariosTitle: 'Examples from the field',
    stepsTitle: 'How we work with it',
    relatedTitle: 'Works well with',
    factSheetTitle: 'At a glance',
    demoTitle: 'See how it works',
    book: 'Book a discovery call',
    solutions: 'Solutions hub',
    cases: 'Client stories',
    explore: 'View page',
    ctaTitle: 'Want to see this on your process?',
    ctaText: 'A short discovery call: map your setup, see a relevant demo, and a realistic rollout plan.',
    homeProducts: 'Product family',
  },
} as const;

const t = ui[locale];
const title = product.titles[locale];
const description = product.descriptions[locale];
const lead = product.leads[locale];
const solutionsHref = localizedPath('/solutions', locale);
const kindHubHref = localizedPath(
  isProduct ? '/solutions#hub-products-title' : '/solutions#hub-services-title',
  locale,
);
const casesHref = localizedPath('/cases', locale);
const homeHref = localizedPath('/#products-family-title', locale);
---

<Layout locale={locale} title={title} description={description}>
  <article class:list={['product-page', `product-brand--${product.logo}`]}>
    <header class="product-hero section">
      <div class="container product-hero__inner">
        <nav class="product-breadcrumb" aria-label={locale === 'he' ? 'מיקום בעמוד' : 'Breadcrumb'}>
          <a href={solutionsHref}>{t.breadcrumbSolutions}</a>
          <span class="product-breadcrumb__sep" aria-hidden="true">/</span>
          <a href={kindHubHref}>{t.breadcrumbKind}</a>
          <span class="product-breadcrumb__sep" aria-hidden="true">/</span>
          <span aria-current="page">{title}</span>
        </nav>

        <div class="product-hero__layout">
          <div class="product-hero__main">
            <div class="product-hero__mark" aria-hidden="true">
              <ProductHeroLogo logo={product.logo} />
            </div>
            <div class="product-hero__copy">
              <p class="product-hero__tag">{t.breadcrumbKind}</p>
              <h1 class="product-hero__title">{title}</h1>
              <p class="product-hero__deck">{description}</p>
              <p class="product-hero__lead">{lead}</p>
              <div class="product-hero__actions">
                <a class="btn btn-primary" href={BOOKING_URL}>{t.book}</a>
                <a class="btn btn-secondary" href={casesHref}>{t.cases}</a>
              </div>
            </div>
          </div>

          <aside class="product-facts card" aria-labelledby="fact-sheet-title">
            <h2 id="fact-sheet-title" class="product-facts__title">{t.factSheetTitle}</h2>
            <dl class="product-facts__list">
              {product.facts[locale].map((row) => (
                <div class="product-facts__row">
                  <dt>{row.term}</dt>
                  <dd>{row.detail}</dd>
                </div>
              ))}
            </dl>
          </aside>
        </div>
      </div>
    </header>

    {
      showDemo && (
        <section class="section product-demo-band" aria-labelledby="demo-title">
          <div class="container">
            <header class="product-section-head">
              <h2 id="demo-title" class="product-section-head__title">{t.demoTitle}</h2>
            </header>
            {product.logo === 'ready' ? (
              <ReadyDeployDemo locale={locale} />
            ) : (
              <ProductDemo locale={locale} logo={product.logo} />
            )}
          </div>
        </section>
      )
    }

    <section class="section product-audience" aria-labelledby="audience-title">
      <div class="container">
        <article class="product-audience__panel">
          <h2 id="audience-title" class="product-audience__label">{t.audienceTitle}</h2>
          <p class="product-audience__text">{product.audience[locale]}</p>
        </article>
      </div>
    </section>

    <section class="section product-problems" aria-labelledby="problems-title">
      <div class="container">
        <h2 id="problems-title" class="product-section-head__title">{t.problemsTitle}</h2>
        <ul class="product-problems__grid" role="list">
          {product.problems[locale].map((item, i) => (
            <li class="product-problems__item">
              <span class="product-problems__index" aria-hidden="true">{i + 1}</span>
              <p>{item}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section product-features" aria-labelledby="features-title">
      <div class="container">
        <h2 id="features-title" class="product-section-head__title">{t.featuresTitle}</h2>
        <ul class="product-features__grid" role="list">
          {product.features[locale].map((f) => (
            <li class="product-features__item">
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section product-scenarios" aria-labelledby="scenarios-title">
      <div class="container">
        <h2 id="scenarios-title" class="product-section-head__title">{t.scenariosTitle}</h2>
        <ul class="product-scenarios__grid" role="list">
          {product.scenarios[locale].map((s) => (
            <li class="product-scenarios__item">
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section product-steps" aria-labelledby="steps-title">
      <div class="container">
        <h2 id="steps-title" class="product-section-head__title">{t.stepsTitle}</h2>
        <ol class="product-steps__track" role="list">
          {product.steps[locale].map((step, i) => (
            <li class="product-steps__item">
              <span class="product-steps__num" aria-hidden="true">{i + 1}</span>
              <div class="product-steps__body">
                <h3>{step.title}</h3>
                <p>{step.body}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    {
      caseStudies.length > 0 && (
        <section class="section product-cases">
          <div class="container">
            <BlogCaseStudiesBlock locale={locale} posts={caseStudies} />
          </div>
        </section>
      )
    }

    {
      related.length > 0 && (
        <section class="section product-related" aria-labelledby="related-title">
          <div class="container">
            <h2 id="related-title" class="product-section-head__title">{t.relatedTitle}</h2>
            <ul class="product-related__grid" role="list">
              {related.map((rel) => (
                <li>
                  <a
                    class="product-related__card card"
                    href={localizedPath(offerPagePath(rel.slug), locale)}
                  >
                    <ProductCardLogo product={rel.logo} label={rel.titles[locale]} />
                    <span class="product-related__explore">
                      {t.explore}
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M3 8h9" />
                        <path d="M8 4l4 4-4 4" />
                      </svg>
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )
    }

    <section class="section product-cta" aria-labelledby="product-cta-title">
      <div class="container">
        <div class="product-cta__panel card">
          <h2 id="product-cta-title" class="product-cta__title">{t.ctaTitle}</h2>
          <p class="product-cta__lead">{t.ctaText}</p>
          <div class="product-cta__actions">
            <a class="btn btn-primary" href={BOOKING_URL}>{t.book}</a>
            <a class="btn btn-secondary" href={solutionsHref}>{t.solutions}</a>
            <a class="btn btn-secondary" href={homeHref}>{t.homeProducts}</a>
          </div>
        </div>
      </div>
    </section>
  </article>
</Layout>

<style>
  .product-page {
    background: var(--color-bg-mesh);
  }

  /* ---- Hero ---- */
  .product-hero {
    padding-block: var(--space-8) var(--space-7);
    border-block-end: 1px solid var(--color-divider);
    background:
      radial-gradient(ellipse 75% 60% at 0% 0%, var(--product-accent-soft, var(--color-accent-muted)), transparent 58%),
      radial-gradient(ellipse 50% 40% at 100% 100%, var(--product-accent-soft, var(--color-accent-muted)), transparent 50%),
      var(--color-surface);
  }

  .product-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin-block-end: var(--space-6);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .product-breadcrumb a {
    color: var(--product-accent, var(--color-accent));
    font-weight: var(--font-weight-medium);
  }

  .product-breadcrumb a:hover {
    color: var(--product-brand-deep, var(--color-accent-hover));
  }

  .product-breadcrumb__sep {
    opacity: 0.45;
    user-select: none;
  }

  .product-breadcrumb [aria-current='page'] {
    color: var(--color-text-secondary);
    font-weight: var(--font-weight-medium);
  }

  .product-hero__layout {
    display: grid;
    gap: var(--space-6);
    align-items: start;
  }

  @media (min-width: 960px) {
    .product-hero__layout {
      grid-template-columns: minmax(0, 1fr) minmax(240px, 300px);
      gap: var(--space-8);
    }
  }

  .product-hero__main {
    display: grid;
    gap: var(--space-5);
  }

  @media (min-width: 640px) {
    .product-hero__main {
      grid-template-columns: auto 1fr;
      gap: var(--space-6) var(--space-7);
      align-items: start;
    }
  }

  .product-hero__mark {
    display: grid;
    place-items: center;
    padding: var(--space-5);
    border-radius: var(--radius-xl);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .product-hero__tag {
    margin: 0 0 var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--product-accent, var(--color-accent));
    letter-spacing: 0.02em;
  }

  .product-hero__title {
    margin: 0 0 var(--space-3);
    font-size: clamp(1.65rem, 4vw, 2.35rem);
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.03em;
    line-height: 1.12;
    text-wrap: balance;
  }

  .product-hero__deck {
    margin: 0 0 var(--space-4);
    font-size: var(--text-md);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-snug);
    color: var(--color-text);
    text-wrap: pretty;
  }

  .product-hero__lead {
    margin: 0 0 var(--space-6);
    max-width: 40rem;
    font-size: var(--text-base);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    text-wrap: pretty;
  }

  .product-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .product-facts {
    padding: var(--space-5) var(--space-6);
    border-color: color-mix(in srgb, var(--product-accent, var(--color-accent)) 22%, var(--color-border));
    background: var(--color-surface-raised);
  }

  .product-facts__title {
    margin: 0 0 var(--space-4);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
  }

  .product-facts__list {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .product-facts__row {
    margin: 0;
    padding-block-start: var(--space-3);
    border-block-start: 1px solid var(--color-divider);
  }

  .product-facts__row:first-child {
    padding-block-start: 0;
    border-block-start: none;
  }

  .product-facts__row dt {
    margin: 0 0 var(--space-1);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--product-accent, var(--color-accent));
  }

  .product-facts__row dd {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-text);
  }

  /* ---- Demo band ---- */
  .product-demo-band {
    padding-block: var(--space-8);
    background: var(--color-surface);
    border-block-end: 1px solid var(--color-divider);
  }

  .product-demo-band .product-section-head {
    margin-block-end: var(--space-5);
  }

  /* ---- Section titles ---- */
  .product-section-head__title {
    margin: 0 0 var(--space-6);
    font-size: clamp(var(--text-xl), 3vw, var(--text-2xl));
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.02em;
    text-align: start;
  }

  /* ---- Audience strip ---- */
  .product-audience__panel {
    max-width: var(--panel-max-wide, 960px);
    margin-inline: auto;
    padding: var(--space-5) var(--space-6);
    border-radius: var(--radius-lg);
    border-inline-start: 4px solid var(--product-accent, var(--color-accent));
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-xs);
  }

  .product-audience__label {
    margin: 0 0 var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    color: var(--product-accent, var(--color-accent));
  }

  .product-audience__text {
    margin: 0;
    font-size: var(--text-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    text-align: start;
  }

  /* ---- Problems ---- */
  .product-problems__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }

  @media (min-width: 720px) {
    .product-problems__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .product-problems__item {
    position: relative;
    margin: 0;
    padding: var(--space-5) var(--space-5) var(--space-5) var(--space-6);
    border-radius: var(--radius-lg);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-xs);
  }

  .product-problems__index {
    position: absolute;
    inset-block-start: var(--space-4);
    inset-inline-start: var(--space-4);
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-extrabold);
    line-height: 1;
    color: color-mix(in srgb, var(--product-accent, var(--color-accent)) 28%, transparent);
    font-variant-numeric: tabular-nums;
  }

  .product-problems__item p {
    margin: 0;
    padding-inline-start: var(--space-6);
    font-size: var(--text-base);
    line-height: var(--line-height-relaxed);
    color: var(--color-text);
    text-align: start;
  }

  /* ---- Features grid ---- */
  .product-features__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .product-features__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .product-features__item {
    padding: var(--space-5) var(--space-6);
    border-radius: var(--radius-lg);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-block-start: 3px solid var(--product-accent, var(--color-accent));
    box-shadow: var(--shadow-xs);
  }

  .product-features__item h3 {
    margin: 0 0 var(--space-2);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    text-align: start;
  }

  .product-features__item p {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    text-align: start;
  }

  /* ---- Scenarios ---- */
  .product-scenarios__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .product-scenarios__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .product-scenarios__item {
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    background: linear-gradient(
      155deg,
      var(--color-surface-raised) 0%,
      color-mix(in srgb, var(--product-accent-soft, var(--color-accent-muted)) 55%, var(--color-surface-raised)) 100%
    );
    border: 1px solid var(--color-border);
  }

  .product-scenarios__item h3 {
    margin: 0 0 var(--space-3);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    text-align: start;
  }

  .product-scenarios__item p {
    margin: 0;
    font-size: var(--text-base);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    text-align: start;
  }

  /* ---- Steps timeline ---- */
  .product-steps__track {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }

  @media (min-width: 800px) {
    .product-steps__track {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-3);
      align-items: stretch;
    }
  }

  .product-steps__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
  }

  .product-steps__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 2rem;
    block-size: 2rem;
    border-radius: var(--radius-full);
    background: var(--product-accent, var(--color-accent));
    color: #fff;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    font-variant-numeric: tabular-nums;
  }

  .product-steps__body h3 {
    margin: 0 0 var(--space-2);
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    text-align: start;
  }

  .product-steps__body p {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    text-align: start;
  }

  /* ---- Related ---- */
  .product-related__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }

  @media (min-width: 560px) {
    .product-related__grid {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }
  }

  .product-related__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-7) var(--space-8);
    min-block-size: 12rem;
    color: var(--color-text);
    transition:
      transform var(--duration-spring) var(--ease-spring),
      box-shadow var(--duration-spring) var(--ease-spring),
      border-color var(--duration-normal) var(--ease-smooth);
  }

  .product-related__card :global(.product-lockup) {
    --logo-scale: clamp(1.5rem, 4.5vw, 2.35rem);
    flex-wrap: nowrap;
    gap: 0.22em;
    width: 100%;
  }

  .product-related__card :global(.product-lockup__mark) {
    height: 1.5em;
  }

  .product-related__card:hover {
    color: var(--color-text);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: color-mix(in srgb, var(--product-accent, var(--color-accent)) 35%, var(--color-border));
  }

  .product-related__explore {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-block-start: auto;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--product-accent, var(--color-accent));
  }

  .product-related__explore svg {
    inline-size: 1rem;
    block-size: 1rem;
    transition: transform var(--transition);
  }

  .product-related__card:hover .product-related__explore svg {
    transform: translateX(3px);
  }

  :global([dir='rtl']) .product-related__card:hover .product-related__explore svg {
    transform: translateX(-3px);
  }

  /* ---- CTA ---- */
  .product-cta__panel {
    max-width: var(--panel-max-wide, 960px);
    margin-inline: auto;
    padding: var(--space-8) var(--space-7);
