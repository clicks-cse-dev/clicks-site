          respond: { tone: 'green', title: 'מענה לתושב', body: 'סגירת לולאה' },
          return: { tone: 'orange', title: 'חזרה לקליטה', body: 'תזכורת' },
        },
        miroDetails: {
          start: 'כל פנייה נכנסת ממופה לנקודת התחלה אחת — לפני שמחלקים למחלקות.',
          intake: 'נציג קולט את הבקשה, בודק שדות חובה ופותח פריט טיוטה בלוח העתידי.',
