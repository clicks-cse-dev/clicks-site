          },
          {
            id: '3',
            group: 'approval',
            name: 'Division manager sign-off',
            owner: 'Manager',
            date: '2 days ago',
            detail: 'Waiting for final approval before resident response.',
            step: 'Manager approval',
          },
          {
            id: '4',
            group: 'done',
            name: 'Reply sent · case #1988',
            owner: 'Service',
            date: '1 week ago',
            detail: 'Loop closed; resident notified on WhatsApp.',
            step: 'Resident response',
          },
          {
            id: '5',
            group: 'intake',
            name: 'Campaign lead · Meta',
            owner: 'Marketing',
            date: 'Today',
            detail: 'Captured via CRM Connections — moves to review tomorrow.',
            step: 'Intake',
          },
        ],
        mondayPick: 'Pick an item from the board',
        mondayFields: { owner: 'Owner', updated: 'Updated', step: 'Map step' },
      };

---

<>
  <div class="product-demo__tabs" role="tablist" aria-label="FlowGram demo">
    {
      t.tabs.map((tab, i) => (
        <button
          type="button"
          class="product-demo__tab"
          role="tab"
          data-demo-tab={tab.id}
          aria-selected={i === 0 ? 'true' : 'false'}
          tabindex={i === 0 ? 0 : -1}
        >
          {tab.label}
        </button>
      ))
    }
  </div>

  <div
    class="product-demo__panel"
    role="tabpanel"
    data-demo-panel="miro"
    data-demo-caption={t.miroCaption}
  >
    <div class="product-demo__frame">
      <div class="product-demo__chrome">
        <span class="product-demo__dot product-demo__dot--a" />
        <span class="product-demo__dot product-demo__dot--b" />
        <span class="product-demo__dot product-demo__dot--c" />
        <span class="product-demo__window-title">{t.miroWindow}</span>
      </div>
      <div class="product-demo__body fg-miro-mock" data-fg-miro>
        <div class="fg-miro-mock__appbar">
          <span class="fg-miro-mock__logo" aria-hidden="true">Miro</span>
          <span class="fg-miro-mock__board">{t.miroBoardName}</span>
          <span class="fg-miro-mock__legend">{t.miroLegend}</span>
        </div>
        <div class="fg-miro-mock__workspace">
          <div class="fg-miro-mock__canvas" dir="ltr">
            <div class="fg-miro-mock__flow-grid">
              {
                t.miroMainFlow.map((id, i) => {
                  const card = t.miroCards[id];
                  return [
                    i > 0 ? <span class="fg-miro-mock__arrow" aria-hidden="true" /> : null,
                    <button
                      type="button"
                      class:list={[
                        'fg-miro-mock__card',
                        `fg-miro-mock__card--${card.tone}`,
                        id === 'intake' && 'is-active',
                      ]}
                      data-fg-miro-card={id}
                      data-fg-miro-title={card.title}
                      data-fg-miro-detail={t.miroDetails[id]}
                    >
                      <span class="fg-miro-mock__card-title">{card.title}</span>
                      <span class="fg-miro-mock__card-body">{card.body}</span>
                    </button>,
                  ];
                })
              }
              <div class="fg-miro-mock__branch-cell">
                <span class="fg-miro-mock__branch-stem" aria-hidden="true" />
                <span class="fg-miro-mock__branch-tag">{t.miroBranchLabel}</span>
                <button
                  type="button"
                  class:list={[
                    'fg-miro-mock__card',
                    `fg-miro-mock__card--${t.miroCards[t.miroBranchId].tone}`,
                  ]}
                  data-fg-miro-card={t.miroBranchId}
                  data-fg-miro-title={t.miroCards[t.miroBranchId].title}
                  data-fg-miro-detail={t.miroDetails[t.miroBranchId]}
                >
                  <span class="fg-miro-mock__card-title">{t.miroCards[t.miroBranchId].title}</span>
                  <span class="fg-miro-mock__card-body">{t.miroCards[t.miroBranchId].body}</span>
                </button>
              </div>
            </div>
          </div>
          <aside class="fg-miro-mock__sidebar">
            <p class="fg-miro-mock__sidebar-label">{t.miroDetailTitle}</p>
            <p class="fg-miro-mock__sidebar-title" data-fg-miro-title>
              {t.miroCards.intake.title}
            </p>
            <p class="fg-miro-mock__sidebar-text" data-fg-miro-detail>
              {t.miroDetails.intake}
            </p>
          </aside>
        </div>
      </div>
    </div>
    <p class="product-demo__caption">{t.miroCaption}</p>
  </div>

  <div
    class="product-demo__panel"
    role="tabpanel"
    data-demo-panel="monday"
    data-demo-caption={t.mondayCaption}
    hidden
  >
    <div class="product-demo__frame">
      <div class="product-demo__chrome">
        <span class="product-demo__dot product-demo__dot--a" />
        <span class="product-demo__dot product-demo__dot--b" />
        <span class="product-demo__dot product-demo__dot--c" />
        <span class="product-demo__window-title">{t.mondayWindow}</span>
      </div>
      <div class="product-demo__body fg-monday-mock" data-fg-monday>
        <header class="fg-monday-mock__head">
          <h3 class="fg-monday-mock__board-title">{t.mondayBoard}</h3>
          <span class="fg-monday-mock__badge">Test</span>
        </header>
        <div class="fg-monday-mock__layout">
          <div class="fg-monday-mock__groups">
            {
              t.mondayGroups.map((group) => (
                <section class="fg-monday-mock__group">
                  <h4 class="fg-monday-mock__group-label">
                    <span class="fg-monday-mock__group-dot" style={`background: ${group.color}`} />
                    {group.label}
                  </h4>
                  <ul class="fg-monday-mock__items" role="list">
                    {
                      t.mondayItems
                        .filter((item) => item.group === group.id)
                        .map((item, i) => (
                          <li>
                            <button
                              type="button"
                              class:list={[
                                'fg-monday-mock__item',
                                group.id === 'review' && i === 0 && 'is-active',
                              ]}
                              data-fg-monday-item={item.id}
                              data-fg-monday-name={item.name}
                              data-fg-monday-detail={item.detail}
                              data-fg-monday-owner={item.owner}
                              data-fg-monday-date={item.date}
                              data-fg-monday-step={item.step}
                            >
                              <span class="fg-monday-mock__item-name">{item.name}</span>
                              <span class="fg-monday-mock__item-meta">
                                {item.owner} · {item.date}
                              </span>
                            </button>
                          </li>
                        ))
                    }
                  </ul>
                </section>
              ))
            }
          </div>
          <aside class="fg-monday-mock__detail">
            <p class="fg-monday-mock__detail-title" data-fg-monday-title>
              {t.mondayItems[1]?.name ?? t.mondayPick}
            </p>
            <p class="fg-monday-mock__detail-text" data-fg-monday-detail-text>
              {t.mondayItems[1]?.detail ?? t.mondayPick}
            </p>
            <dl class="fg-monday-mock__detail-fields">
              <div>
                <dt>{t.mondayFields.owner}</dt>
                <dd data-fg-monday-owner>{t.mondayItems[1]?.owner}</dd>
              </div>
              <div>
                <dt>{t.mondayFields.updated}</dt>
                <dd data-fg-monday-date>{t.mondayItems[1]?.date}</dd>
              </div>
              <div>
                <dt>{t.mondayFields.step}</dt>
                <dd data-fg-monday-step>{t.mondayItems[1]?.step}</dd>
              </div>
            </dl>
          </aside>
        </div>
      </div>
    </div>
    <p class="product-demo__caption">{t.mondayCaption}</p>
  </div>
</>
