            step: 'קליטת בקשה',
          },
          {
            id: '2',
            group: 'review',
            name: 'בדיקת זכאות · מגרש 412',
            owner: 'רישוי',
            date: 'אתמול',
            detail: 'בדיקה מול רישום; חסר תשריט — יוחזר לקליטה לפי המפה.',
            step: 'בדיקת זכאות',
          },
          {
            id: '3',
            group: 'approval',
            name: 'אישור מנהל אגף',
            owner: 'מנהל',
            date: 'לפני 2 ימים',
            detail: 'ממתין לאישור סופי לפני מענה לתושב.',
