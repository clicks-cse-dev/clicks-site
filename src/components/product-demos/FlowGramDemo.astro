        miroBoardName: 'Process design · Service requests',
        miroMainFlow: ['start', 'intake', 'check', 'approve', 'respond'] as const,
        miroBranchLabel: 'Missing info?',
        miroBranchId: 'return' as const,
        miroCards: {
          start: { tone: 'violet', title: 'Start', body: 'Inbound' },
          intake: { tone: 'yellow', title: 'Intake', body: 'Item + assign' },
          check: { tone: 'blue', title: 'Eligibility', body: 'Registry · docs' },
