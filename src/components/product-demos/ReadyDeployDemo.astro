      widgets: [
        { value: '128', label: 'Open', color: '#579bfc' },
        { value: '11', label: 'SLA breaches', color: '#e85d4c' },
        { value: '96%', label: 'On target', color: '#00c875' },
        { value: '42', label: 'Closed this week', color: '#784bd1' },
      ],
      chartTitle: 'Request volume by week',
      weeks: [
        { label: 'Wk 1', h: 48 },
