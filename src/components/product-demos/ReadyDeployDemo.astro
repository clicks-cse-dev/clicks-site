        { label: 'Wk 4', h: 88 },
      ],
    },
  },
} as const;

const c = t[locale];

const groupColors4 = Object.fromEntries(
  caseGroups4.map((g) => [g.id, g.color]),
) as Record<string, string>;

function findItem<T extends { id: string }>(items: readonly T[], id: string) {
  return items.find((item) => item.id === id) ?? items[0];
}

const crmDefault = findItem(c.crm360.rows, c.crm360.defaultRowId);
const crmDefaultChannel = c.crm360.channels[0];
const crmDefaultThread = c.crm360.threads[crmDefaultChannel as keyof typeof c.crm360.threads];
const caseDefault = findItem(c.cases.items, c.cases.defaultItemId);
---

<div
  class="product-demo product-brand--ready"
  data-product-demo
  data-demo-kind="ready"
  data-live-prefix={c.livePrefix}
>
  <p class="product-demo__live" data-demo-live aria-live="polite">
    {c.livePrefix} {c.crm360.caption}
  </p>

  <div class="product-demo__tabs" role="tablist" aria-label={locale === 'he' ? 'חבילות מוכנות להטמעה' : 'Ready-to-deploy packs'}>
    {
      c.tabs.map((tab, i) => (
        <button
          type="button"
          class="product-demo__tab"
          role="tab"
          data-demo-tab={tab.id}
          aria-selected={i === 0 ? 'true' : 'false'}
          tabindex={i === 0 ? 0 : -1}
        >
          {tab.label}
        </button>
      ))
    }
  </div>

  <!-- CRM 360 · CRM Connections board -->
  <div
    class="product-demo__panel"
    role="tabpanel"
    data-demo-panel="crm360"
    data-demo-caption={c.crm360.caption}
  >
    <div class="product-demo__frame product-brand--crm">
      <div class="product-demo__chrome">
        <span class="product-demo__dot product-demo__dot--a" />
        <span class="product-demo__dot product-demo__dot--b" />
        <span class="product-demo__dot product-demo__dot--c" />
        <span class="product-demo__window-title">{c.crm360.window}</span>
      </div>
      <div class="product-demo__body crm-board-mock" data-ready-crm-board>
        <header class="crm-board-mock__head">
          <h3 class="crm-board-mock__title">{c.crm360.board}</h3>
          <span class="crm-board-mock__badge">{c.crm360.badge}</span>
        </header>
        <div class="crm-board-mock__workspace">
          <div class="product-demo__tabs product-demo__tabs--inner" role="tablist">
            {
              c.crm360.channels.map((ch, i) => (
                <button
                  type="button"
                  class="product-demo__tab"
                  role="tab"
                  data-ready-crm-channel={ch}
                  data-ready-crm-thread={c.crm360.threads[ch as keyof typeof c.crm360.threads]}
                  aria-selected={i === 0 ? 'true' : 'false'}
                >
                  {ch}
                </button>
              ))
            }
          </div>
          <p class="crm-board-mock__thread" data-ready-crm-thread>{crmDefaultThread}</p>
          <p class="crm-board-mock__linked">
            <span class="crm-board-mock__sync-dot" aria-hidden="true" />
            {c.crm360.linked}
          </p>
          <div class="crm-board-mock__layout">
            <div class="crm-board-mock__table">
              <div class="mini-board__row mini-board__row--head crm-board-mock__row">
                <span>{c.crm360.cols.task}</span>
                <span>{c.crm360.cols.source}</span>
                <span>{c.crm360.cols.status}</span>
                <span>{c.crm360.cols.owner}</span>
              </div>
              {
                c.crm360.rows.map((row) => (
                  <button
                    type="button"
                    class:list={[
                      'mini-board__row',
                      'mini-board__row--click',
                      'crm-board-mock__row',
                      row.id === c.crm360.defaultRowId && 'is-selected',
                    ]}
                    data-ready-crm-row
                    data-task={row.task}
                    data-source={row.source}
                    data-owner={row.owner}
                    data-detail={row.detail}
                    data-sla={row.sla}
                  >
                    <span>{row.task}</span>
                    <span>{row.source}</span>
                    <span>
                      <span class:list={['mini-status', `mini-status--${row.status}`]}>
                        {row.statusLabel}
                      </span>
                    </span>
                    <span>{row.owner}</span>
                  </button>
                ))
              }
            </div>
            <aside class="crm-board-mock__detail">
              <p class="crm-board-mock__detail-title" data-ready-crm-title>
                {crmDefault?.task ?? c.crm360.pick}
              </p>
              <p class="crm-board-mock__detail-text" data-ready-crm-detail>
                {crmDefault?.detail ?? c.crm360.pick}
              </p>
              <div class="cms-mock__row">
                <span class="cms-mock__row-label">{c.crm360.fields.owner}</span>
                <span data-ready-crm-owner>{crmDefault?.owner}</span>
              </div>
              <div class="cms-mock__row">
                <span class="cms-mock__row-label">{c.crm360.fields.source}</span>
                <span data-ready-crm-source>{crmDefault?.source}</span>
              </div>
              <div class="cms-mock__row">
                <span class="cms-mock__row-label">{c.crm360.fields.sla}</span>
                <span data-ready-crm-sla>{crmDefault?.sla}</span>
              </div>
            </aside>
          </div>
        </div>
      </div>
    </div>
    <p class="product-demo__caption">{c.crm360.caption}</p>
  </div>

  <!-- Case management · Kanban + files -->
  <div
    class="product-demo__panel"
    role="tabpanel"
    data-demo-panel="cases"
    data-demo-caption={c.cases.caption}
    hidden
  >
    <div class="product-demo__frame">
      <div class="product-demo__chrome">
        <span class="product-demo__dot product-demo__dot--a" />
        <span class="product-demo__dot product-demo__dot--b" />
        <span class="product-demo__dot product-demo__dot--c" />
        <span class="product-demo__window-title">{c.window}</span>
      </div>
      <div class="product-demo__body fg-monday-mock" data-ready-monday="cases">
        <header class="fg-monday-mock__head">
          <h3 class="fg-monday-mock__board-title">{c.cases.board}</h3>
          <span class="fg-monday-mock__badge">{c.cases.badge}</span>
        </header>
        <div class="fg-monday-mock__layout">
          <div class="fg-monday-mock__groups">
            {
              c.cases.groups.map((group) => (
                <section class="fg-monday-mock__group">
                  <h4 class="fg-monday-mock__group-label">
                    <span
                      class="fg-monday-mock__group-dot"
                      style={`background: ${groupColors4[group.id]}`}
                    />
                    {group.label}
                  </h4>
                  <ul class="fg-monday-mock__items" role="list">
                    {
                      c.cases.items
                        .filter((item) => item.group === group.id)
                        .map((item) => (
                          <li>
                            <button
                              type="button"
                              class:list={[
                                'fg-monday-mock__item',
                                item.id === c.cases.defaultItemId && 'is-active',
                              ]}
                              data-ready-monday-item
                              data-id={item.id}
                              data-name={item.name}
                              data-detail={item.detail}
                              data-owner={item.owner}
                              data-date={item.date}
                              data-sla={item.sla}
                              data-docs={item.docs}
                              data-show-files={item.id === c.cases.defaultItemId ? 'true' : 'false'}
                            >
                              <span class="fg-monday-mock__item-name">{item.name}</span>
                              <span class="fg-monday-mock__item-meta">
                                {item.owner} · {item.date}
                              </span>
                            </button>
                          </li>
                        ))
                    }
                  </ul>
                </section>
              ))
            }
          </div>
          <aside class="fg-monday-mock__detail fg-monday-mock__detail--wide">
            <p class="fg-monday-mock__detail-title" data-ready-monday-title>
              {caseDefault?.name ?? c.cases.pick}
            </p>
            <p class="fg-monday-mock__detail-text" data-ready-monday-detail>
              {caseDefault?.detail ?? c.cases.pick}
            </p>
            <dl class="fg-monday-mock__detail-fields">
              <div>
                <dt>{c.cases.fields.owner}</dt>
                <dd data-ready-monday-owner>{caseDefault?.owner}</dd>
              </div>
              <div>
                <dt>{c.cases.fields.sla}</dt>
                <dd data-ready-monday-sla>{caseDefault?.sla}</dd>
              </div>
              <div>
                <dt>{c.cases.fields.docs}</dt>
                <dd data-ready-monday-docs>{caseDefault?.docs}</dd>
              </div>
            </dl>
            <ul class="mndy-file-chips" data-ready-monday-files>
              {c.cases.fileList.map((file) => (
                <li>{file}</li>
              ))}
            </ul>
          </aside>
        </div>
      </div>
    </div>
    <p class="product-demo__caption">{c.cases.caption}</p>
  </div>

  <!-- Onboarding · Main table -->
  <div
    class="product-demo__panel"
    role="tabpanel"
    data-demo-panel="onboarding"
    data-demo-caption={c.onboarding.caption}
    hidden
  >
    <div class="product-demo__frame">
      <div class="product-demo__chrome">
        <span class="product-demo__dot product-demo__dot--a" />
        <span class="product-demo__dot product-demo__dot--b" />
        <span class="product-demo__dot product-demo__dot--c" />
        <span class="product-demo__window-title">{c.window}</span>
      </div>
      <div class="product-demo__body fg-monday-mock" data-ready-table>
        <header class="fg-monday-mock__head">
          <h3 class="fg-monday-mock__board-title">{c.onboarding.board}</h3>
          <span class="fg-monday-mock__badge">{c.onboarding.badge}</span>
        </header>
        <div class="mndy-workspace">
          <div class="mndy-toolbar">
            <button type="button" class="mndy-toolbar__primary">{c.onboarding.newItem}</button>
            <button type="button" class="mndy-toolbar__ghost">{c.onboarding.filter}</button>
          </div>
          <div class="mndy-table" role="table">
            <div class="mndy-table__row mndy-table__row--head" role="row">
              <span role="columnheader">{c.onboarding.cols.task}</span>
              <span role="columnheader">{c.onboarding.cols.source}</span>
              <span role="columnheader">{c.onboarding.cols.status}</span>
              <span role="columnheader">{c.onboarding.cols.sla}</span>
              <span role="columnheader">{c.onboarding.cols.owner}</span>
            </div>
            {
              c.onboarding.rows.map((row, i) => (
                <button
                  type="button"
                  class:list={['mndy-table__row', 'mndy-table__row--data', i === 0 && 'is-selected']}
                  role="row"
                  data-ready-table-row
                  data-task={row.task}
                  data-source={row.source}
                  data-sla={row.sla}
                >
                  <span class="mndy-table__task" role="cell">{row.task}</span>
                  <span role="cell">{row.source}</span>
                  <span role="cell">
                    <span class:list={['mndy-pill', `mndy-pill--${row.status}`]}>{row.statusLabel}</span>
                  </span>
                  <span role="cell">
                    <span class="mndy-pill mndy-pill--sla">{row.sla}</span>
                  </span>
                  <span class="mndy-table__owner" role="cell">
                    <span class="mndy-avatar" aria-hidden="true">{row.ownerInit}</span>
                    {row.owner}
                  </span>
                </button>
              ))
            }
          </div>
          <div class="mndy-table-kpis">
            <div class="mndy-table-kpis__card">
              <span class="mndy-table-kpis__value">94%</span>
              <span class="mndy-table-kpis__label">{locale === 'he' ? 'עמידה ב-SLA' : 'SLA met'}</span>
            </div>
            <div class="mndy-table-kpis__card">
              <span class="mndy-table-kpis__value">51</span>
              <span class="mndy-table-kpis__label">{locale === 'he' ? 'פתוחות השבוע' : 'Open this week'}</span>
            </div>
            <div class="mndy-table-kpis__card">
              <span class="mndy-table-kpis__value">1.8</span>
              <span class="mndy-table-kpis__label">{locale === 'he' ? 'ימים ממוצע' : 'Avg days'}</span>
            </div>
          </div>
          <p class="mndy-table__hint" data-ready-table-hint>{c.onboarding.pick}</p>
        </div>
      </div>
    </div>
    <p class="product-demo__caption">{c.onboarding.caption}</p>
  </div>

  <!-- Dashboard · Widgets -->
  <div
    class="product-demo__panel"
    role="tabpanel"
    data-demo-panel="dashboard"
    data-demo-caption={c.dashboard.caption}
    hidden
  >
    <div class="product-demo__frame">
      <div class="product-demo__chrome">
        <span class="product-demo__dot product-demo__dot--a" />
        <span class="product-demo__dot product-demo__dot--b" />
        <span class="product-demo__dot product-demo__dot--c" />
        <span class="product-demo__window-title">{c.window}</span>
      </div>
      <div class="product-demo__body fg-monday-mock">
        <header class="fg-monday-mock__head">
          <h3 class="fg-monday-mock__board-title">{c.dashboard.board}</h3>
          <span class="fg-monday-mock__badge">{c.dashboard.badge}</span>
        </header>
        <div class="mndy-workspace mndy-dash">
          <div class="mndy-dash__widgets">
            {
              c.dashboard.widgets.map((w) => (
                <div class="mndy-dash__widget">
                  <span class="mndy-dash__widget-bar" style={`background: ${w.color}`} />
                  <p class="mndy-dash__widget-value">{w.value}</p>
                  <p class="mndy-dash__widget-label">{w.label}</p>
                </div>
              ))
            }
          </div>
          <section class="mndy-dash__chart">
            <h4 class="mndy-dash__chart-title">{c.dashboard.chartTitle}</h4>
            <div class="mndy-dash__bars" aria-hidden="true">
              {
                c.dashboard.weeks.map((w) => (
                  <div class="mndy-dash__bar-wrap">
                    <div class="mndy-dash__bar" style={`--h: ${w.h}`} />
                    <span>{w.label}</span>
                  </div>
                ))
              }
            </div>
          </section>
        </div>
      </div>
    </div>
    <p class="product-demo__caption">{c.dashboard.caption}</p>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-product-demo][data-demo-kind="ready"]').forEach((root) => {
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-demo-tab]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-demo-panel]'));
    const live = root.querySelector<HTMLElement>('[data-demo-live]');

    const selectTab = (id: string) => {
      tabs.forEach((tab) => {
        const on = tab.dataset.demoTab === id;
        tab.setAttribute('aria-selected', on ? 'true' : 'false');
        tab.tabIndex = on ? 0 : -1;
      });
      panels.forEach((panel) => {
        const on = panel.dataset.demoPanel === id;
        panel.hidden = !on;
        if (on && live) {
          const cap = panel.dataset.demoCaption ?? '';
          live.textContent = `${root.dataset.livePrefix ?? ''} ${cap}`;
        }
      });
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => selectTab(tab.dataset.demoTab!));
      tab.addEventListener('keydown', (e) => {
        if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
        e.preventDefault();
        const rtl = document.documentElement.dir === 'rtl';
        const fwd = rtl ? e.key === 'ArrowLeft' : e.key === 'ArrowRight';
        const next = (i + (fwd ? 1 : -1) + tabs.length) % tabs.length;
        tabs[next].focus();
        selectTab(tabs[next].dataset.demoTab!);
      });
    });

    root.querySelectorAll<HTMLElement>('[data-ready-crm-board]').forEach((box) => {
      const thread = box.querySelector<HTMLElement>('[data-ready-crm-thread]');
      box.querySelectorAll<HTMLButtonElement>('[data-ready-crm-channel]').forEach((btn) => {
        btn.addEventListener('click', () => {
          box.querySelectorAll('[data-ready-crm-channel]').forEach((b) => {
            b.setAttribute('aria-selected', 'false');
          });
          btn.setAttribute('aria-selected', 'true');
          if (thread) thread.textContent = btn.dataset.readyCrmThread ?? '';
        });
      });

      const title = box.querySelector<HTMLElement>('[data-ready-crm-title]');
      const detail = box.querySelector<HTMLElement>('[data-ready-crm-detail]');
      const owner = box.querySelector<HTMLElement>('[data-ready-crm-owner]');
      const source = box.querySelector<HTMLElement>('[data-ready-crm-source]');
      const sla = box.querySelector<HTMLElement>('[data-ready-crm-sla]');

      const selectRow = (btn: HTMLButtonElement) => {
        box.querySelectorAll('[data-ready-crm-row]').forEach((r) => r.classList.remove('is-selected'));
        btn.classList.add('is-selected');
        if (title) title.textContent = btn.dataset.task ?? '';
        if (detail) detail.textContent = btn.dataset.detail ?? '';
        if (owner) owner.textContent = btn.dataset.owner ?? '';
        if (source) source.textContent = btn.dataset.source ?? '';
        if (sla) sla.textContent = btn.dataset.sla ?? '';
      };

      box.querySelectorAll<HTMLButtonElement>('[data-ready-crm-row]').forEach((btn) => {
        btn.addEventListener('click', () => selectRow(btn));
      });
      const selected = box.querySelector<HTMLButtonElement>('[data-ready-crm-row].is-selected');
      if (selected) selectRow(selected);
    });

    root.querySelectorAll<HTMLElement>('[data-ready-monday]').forEach((box) => {
      const title = box.querySelector<HTMLElement>('[data-ready-monday-title]');
      const detail = box.querySelector<HTMLElement>('[data-ready-monday-detail]');
      const owner = box.querySelector<HTMLElement>('[data-ready-monday-owner]');
      const source = box.querySelector<HTMLElement>('[data-ready-monday-source]');
      const sla = box.querySelector<HTMLElement>('[data-ready-monday-sla]');
      const docs = box.querySelector<HTMLElement>('[data-ready-monday-docs]');
      const files = box.querySelector<HTMLElement>('[data-ready-monday-files]');

      const activate = (btn: HTMLButtonElement) => {
        box.querySelectorAll('[data-ready-monday-item]').forEach((b) => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        if (title) title.textContent = btn.dataset.name ?? '';
        if (detail) detail.textContent = btn.dataset.detail ?? '';
        if (owner) owner.textContent = btn.dataset.owner ?? '';
        if (source) source.textContent = btn.dataset.source ?? '';
        if (sla) sla.textContent = btn.dataset.sla ?? '';
        if (docs) docs.textContent = btn.dataset.docs ?? '';
        if (files) files.hidden = btn.dataset.showFiles !== 'true';
      };

      box.querySelectorAll<HTMLButtonElement>('[data-ready-monday-item]').forEach((btn) => {
        btn.addEventListener('click', () => activate(btn));
      });
      const active = box.querySelector<HTMLButtonElement>('[data-ready-monday-item].is-active');
      if (active) activate(active);
    });

    root.querySelectorAll<HTMLElement>('[data-ready-table]').forEach((box) => {
      const hint = box.querySelector<HTMLElement>('[data-ready-table-hint]');
      const baseHint = hint?.textContent ?? '';
      box.querySelectorAll<HTMLButtonElement>('[data-ready-table-row]').forEach((btn) => {
        btn.addEventListener('click', () => {
          box.querySelectorAll('[data-ready-table-row]').forEach((r) => r.classList.remove('is-selected'));
          btn.classList.add('is-selected');
          if (hint) {
            hint.textContent = `${baseHint} · ${btn.dataset.task ?? ''} (${btn.dataset.source ?? ''})`;
          }
        });
      });
    });
  });
</script>
