---
import Layout from '../layouts/Layout.astro';
import ReadyDeployDemo from './product-demos/ReadyDeployDemo.astro';
import ProductCardLogo from './product-logos/ProductCardLogo.astro';
import './product-logos/ProductLockup.css';
import { localizedPath, type Locale } from '../i18n';
import { BOOKING_URL, WHATSAPP } from '../config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const content = {
  he: {
    title: 'חבילות monday מוכנות להטמעה',
    description: 'CRM 360, ניהול תיקים, קליטה, SLA ודשבורדים להטמעה מהירה.',
    eyebrow: 'מוצר',
    h1: 'חבילות מוכנות להטמעה על monday',
    lead: 'תבניות עבודה שכבר עברו שטח, מותאמות לפי סוג הארגון. לא מתחילים מדף ריק.',
    packsTitle: 'חבילות נפוצות',
    demoHint: 'בחרו חבילה כדי לראות דוגמה אינטראקטיבית על הלוח.',
    packs: [
      {
        name: 'CRM 360',
        body: 'מסע לקוח/תושב מקצה לקצה: קליטה, טיפול, מדידה ודוחות למנהלים.',
      },
      {
        name: 'ניהול תיקים',
        body: 'תיק אישי או ארגוני עם SLA, מסמכים, הרשאות ומעקב אחרי סטטוס.',
      },
      {
        name: 'קליטה + SLA',
        body: 'תבניות קליטה, מדדי שירות ודשבורד שמראה עומסים וזמני טיפול.',
      },
      {
        name: 'דשבורד מנהלים',
        body: 'תמונת מצב שבועית: פתוחות, חריגות ועמידה ביעדים שהוגדרו מראש.',
      },
    ],
    includesTitle: 'מה כלול בדרך כלל',
    includes: [
      'לוחות monday מוגדרים מראש עם שדות וסטטוסים',
      'אוטומציות בסיסיות לניתוב והתראות',
      'הדרכת צוות והתאמה קלה לשמות ומחלקות',
      'אפשרות להרחיב עם FlowGram, CRM Connections ו-Clicks TSM',
    ],
    book: 'לקביעת שיחת ייעוץ',
    products: 'משפחת המוצרים',
    contact: 'צרו קשר',
    ctaTitle: 'צריכים הטמעה מהירה?',
    ctaText: 'נבין את המגזר והתהליך שלכם ונציע חבילה מתאימה — עם הדגמה על לוח חי.',
  },
  en: {
    title: 'Ready monday implementation packs',
    description: 'CRM 360, case management, onboarding/SLA and dashboards — for a fast rollout.',
    eyebrow: 'Product',
    h1: 'Ready-to-deploy — built for rollout',
    lead: 'Field-tested work templates tailored to your organization type. Not a blank board.',
    packsTitle: 'Common packs',
    demoHint: 'Pick a pack to see an interactive board example.',
    packs: [
      {
        name: 'CRM 360',
        body: 'End-to-end resident or customer journey: intake, handling, metrics and leadership reports.',
      },
      {
        name: 'Case management',
        body: 'Individual or organizational case file with SLA, documents, permissions and status tracking.',
      },
      {
        name: 'Onboarding + SLA',
        body: 'Intake templates, service metrics and a dashboard for load and handling time.',
      },
      {
        name: 'Executive dashboard',
        body: 'Weekly snapshot: open items, exceptions and progress against agreed targets.',
      },
    ],
    includesTitle: 'What is usually included',
    includes: [
      'Pre-built monday boards with fields and statuses',
      'Core automations for routing and notifications',
      'Team training and light customization of names and departments',
      'Room to extend with FlowGram, CRM Connections and Clicks TSM',
    ],
    book: 'Book a discovery call',
    products: 'Product family',
    contact: 'Contact us',
    ctaTitle: 'Need a fast rollout?',
    ctaText: 'We will understand your sector and process and recommend a fitting pack — with a live board demo.',
  },
} as const;

const t = content[locale];
const productsHref = localizedPath('/#products-family-title', locale);
const crmHref = localizedPath('/services/crm-connections', locale);
---

<Layout locale={locale} title={t.title} description={t.description}>
  <article class="inner-page solution-page">
    <header class="inner-hero product-brand--ready">
      <div class="container inner-hero__grid">
        <div class="inner-hero__copy">
          <p class="inner-hero__eyebrow">{t.eyebrow}</p>
          <div class="inner-hero__logo">
            <ProductCardLogo product="ready" label="Ready-to-deploy" />
          </div>
          <h1 class="page__title">{t.h1}</h1>
          <p class="inner-hero__lead">{t.lead}</p>
          <div class="inner-hero__actions">
            <a class="btn btn-primary" href={BOOKING_URL}>{t.book}</a>
            <a class="btn btn-secondary" href={crmHref}>
              {locale === 'he' ? 'CRM Connections' : 'CRM Connections'}
            </a>
          </div>
        </div>
      </div>
    </header>

    <div class="container inner-body">
      <section class="inner-section" aria-labelledby="packs-title">
        <header class="inner-section__head">
          <h2 id="packs-title" class="inner-section__title">{t.packsTitle}</h2>
        </header>
        <p class="inner-section__intro solution-page__demo-hint">{t.demoHint}</p>
        <ReadyDeployDemo locale={locale} />
        <ul class="detail-list solution-page__pack-summary" role="list">
          {t.packs.map((p) => (
            <li class="detail-list__item">
              <h3>{p.name}</h3>
              <p>{p.body}</p>
            </li>
          ))}
        </ul>
      </section>

      <section class="inner-section" aria-labelledby="includes-title">
        <header class="inner-section__head">
          <h2 id="includes-title" class="inner-section__title">{t.includesTitle}</h2>
        </header>
        <ul class="problem-list" role="list">
          {t.includes.map((item) => (
            <li class="problem-list__item">{item}</li>
          ))}
        </ul>
      </section>

      <div class="inner-cta-band">
        <h2 class="inner-cta-band__title">{t.ctaTitle}</h2>
        <p class="inner-cta-band__text">{t.ctaText}</p>
        <div class="inner-cta-band__actions">
          <a class="btn btn-primary" href={BOOKING_URL}>{t.book}</a>
          <a class="btn btn-secondary" href={productsHref}>{t.products}</a>
          <a class="btn btn-secondary" href={WHATSAPP} target="_blank" rel="noopener noreferrer">
            {t.contact}
          </a>
        </div>
      </div>
    </div>
  </article>
</Layout>
