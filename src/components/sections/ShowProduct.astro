---
/**
 * ShowProduct section (PRD §7 #8, §4 "Beat" #1 — the category whitespace).
 * The #1 differentiator: SHOW real working systems. No competitor does this.
 *
 * Since real product captures are still pending (PRD §12 Q7), this builds clean,
 * on-brand CSS/SVG mockups of three surfaces — a monday.com board, a FlowGram
 * process map and a Clicks TSM dashboard.
 *
 * TODO(PRD §12 Q7): swap these CSS/SVG mockups for real, anonymized product
 * captures (monday boards, FlowGram blueprint, Clicks TSM SLA view)
 * + a short looping demo (muted, lazy-loaded <video>, respecting reduced-motion).
 *
 * Contract: takes a `locale` prop; inline { he, en } content; scoped styles;
 * tokens only; RTL via logical properties; bans honored (no gradient text,
 * no nested cards, no side-stripe alerts, no purple-hero wash).
 */
import type { Locale } from '../../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const content = {
  he: {
    eyebrow: 'מראים את המוצר',
    title: 'כך נראית מערכת שבנינו על monday.com',
    lead: 'הצצה ללוח monday.com, מפת FlowGram ולוח Clicks TSM: פניות, תהליך, אחריות, מדדים ותחזוקה באותו רצף עבודה.',
    tabs: [
      { id: 'board', label: 'לוח monday.com' },
      { id: 'flowgram', label: 'מפת תהליך — FlowGram' },
      { id: 'tsm', label: 'לוח בקרה — Clicks TSM' },
    ],
    board: {
      caption: 'CRM 360: פנייה נכנסת, עוברת לאחראי ונשארת במעקב עד סגירה על לוח אחד.',
      window: 'CRM 360 · פניות תושבים',
      groups: [
        {
          name: 'פניות חדשות',
          rows: [
            { task: 'בקשת היתר — רח׳ הזית 9', owner: 'ד', status: 'בטיפול', statusKey: 'progress', date: '12 ביוני' },
            { task: 'תלונת תושב — תאורת רחוב', owner: 'מ', status: 'ממתין', statusKey: 'pending', date: '14 ביוני' },
          ],
        },
        {
          name: 'בטיפול',
          rows: [
            { task: 'רישוי עסק — מאפייה', owner: 'ס', status: 'הושלם', statusKey: 'done', date: '9 ביוני' },
            { task: 'מענק קהילתי — בקשה 341', owner: 'א', status: 'בטיפול', statusKey: 'progress', date: '18 ביוני' },
          ],
        },
      ],
      cols: { task: 'משימה', owner: 'אחראי', status: 'סטטוס', date: 'תאריך יעד' },
      legend: { done: 'הושלם', progress: 'בטיפול', pending: 'ממתין' },
    },
    flowgram: {
      caption: 'FlowGram: מפת תהליך אישור לפני שמתחילים לבנות את הלוחות.',
      window: 'FlowGram · מפת תהליך',
      nodes: [
        { label: 'קליטת בקשה' },
        { label: 'בדיקת זכאות' },
        { label: 'אישור גורם מוסמך' },
        { label: 'הנפקת מענה' },
      ],
      branchYes: 'אושר',
      branchNo: 'חסר מידע',
    },
    tsm: {
      caption: 'Clicks TSM — בקרת SLA, קריאות שירות וזמינות מערכת במבט אחד.',
      window: 'Clicks TSM · בקרת שירות',
      kpis: [
        { value: '98.6%', label: 'עמידה ב-SLA' },
        { value: '12', label: 'קריאות פתוחות' },
        { value: '2.4ש׳', label: 'זמן תגובה ממוצע' },
      ],
      chartTitle: 'קריאות שירות — 7 ימים',
      tickets: [
        { id: '#1042', title: 'תקלת סנכרון ArcGIS', sev: 'גבוה', sevKey: 'high', sla: 'בזמן' },
        { id: '#1039', title: 'בקשת הרשאה — לוח CRM', sev: 'בינוני', sevKey: 'mid', sla: 'בזמן' },
        { id: '#1031', title: 'דוח חודשי — אוטומציה', sev: 'נמוך', sevKey: 'low', sla: 'הושלם' },
      ],
      cols: { id: 'מזהה', title: 'נושא', sev: 'חומרה', sla: 'SLA' },
      liveLabel: 'נתונים חיים',
    },
  },
  en: {
    eyebrow: 'Show the product',
    title: 'What a Clicks monday.com system looks like',
    lead: 'A look inside a monday.com board, a FlowGram map and a Clicks TSM dashboard: requests, process, ownership, metrics and maintenance in one work path.',
    tabs: [
      { id: 'board', label: 'monday.com board' },
      { id: 'flowgram', label: 'FlowGram process map' },
      { id: 'tsm', label: 'Clicks TSM dashboard' },
    ],
    board: {
      caption: 'CRM 360: a request enters, moves to an owner and stays tracked through resolution on one board.',
      window: 'CRM 360 · Resident requests',
      groups: [
        {
          name: 'New requests',
          rows: [
            { task: 'Permit request — 9 Hazait St.', owner: 'D', status: 'Working on it', statusKey: 'progress', date: 'Jun 12' },
            { task: 'Resident report — street lighting', owner: 'M', status: 'Pending', statusKey: 'pending', date: 'Jun 14' },
          ],
        },
        {
          name: 'In progress',
          rows: [
            { task: 'Business license — bakery', owner: 'S', status: 'Done', statusKey: 'done', date: 'Jun 9' },
            { task: 'Community grant — request 341', owner: 'A', status: 'Working on it', statusKey: 'progress', date: 'Jun 18' },
          ],
        },
      ],
      cols: { task: 'Item', owner: 'Owner', status: 'Status', date: 'Due date' },
      legend: { done: 'Done', progress: 'Working on it', pending: 'Pending' },
    },
    flowgram: {
      caption: 'FlowGram: the approval process mapped before the boards are built.',
      window: 'FlowGram · Process blueprint',
      nodes: [
        { label: 'Intake request' },
        { label: 'Eligibility check' },
        { label: 'Authorized approval' },
        { label: 'Issue response' },
      ],
      branchYes: 'Approved',
      branchNo: 'Missing info',
    },
    tsm: {
      caption: 'Clicks TSM — SLA health, service tickets and system uptime at a glance.',
      window: 'Clicks TSM · Service control',
      kpis: [
        { value: '98.6%', label: 'SLA met' },
        { value: '12', label: 'Open tickets' },
        { value: '2.4h', label: 'Avg. response' },
      ],
      chartTitle: 'Service tickets — 7 days',
      tickets: [
        { id: '#1042', title: 'ArcGIS sync error', sev: 'High', sevKey: 'high', sla: 'On time' },
        { id: '#1039', title: 'Permission request — CRM board', sev: 'Medium', sevKey: 'mid', sla: 'On time' },
        { id: '#1031', title: 'Monthly report — automation', sev: 'Low', sevKey: 'low', sla: 'Done' },
      ],
      cols: { id: 'ID', title: 'Subject', sev: 'Severity', sla: 'SLA' },
      liveLabel: 'Live data',
    },
  },
} as const;

const t = content[locale];

// TODO: when real captures arrive, these placeholder bar heights become real
// 7-day ticket counts pulled from a sanitized export.
const ticketBars = [40, 62, 48, 78, 55, 70, 90];
---

<section class="section show-product" aria-labelledby="show-product-title">
  <div class="container">
    <header class="sp-head" data-reveal>
      <p class="eyebrow">{t.eyebrow}</p>
      <h2 id="show-product-title">{t.title}</h2>
      <p class="sp-lead">{t.lead}</p>
    </header>

    <div class="sp-tabs" role="tablist" aria-label={t.eyebrow} data-reveal style="--reveal-delay: 60ms">
      {
        t.tabs.map((tab, i) => (
          <button
            type="button"
            role="tab"
            id={`sp-tab-${tab.id}`}
            class="sp-tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`sp-panel-${tab.id}`}
            tabindex={i === 0 ? 0 : -1}
            data-tab={tab.id}
          >
            {tab.label}
          </button>
        ))
      }
    </div>

    <!-- ============================ BOARD ============================ -->
    <div
      class="sp-panel"
      id="sp-panel-board"
      role="tabpanel"
      aria-labelledby="sp-tab-board"
      data-panel="board"
    >
      <figure class="sp-figure">
        <div class="sp-frame" aria-hidden="false">
          <div class="sp-window">
            <span class="sp-dot sp-dot--a"></span>
            <span class="sp-dot sp-dot--b"></span>
            <span class="sp-dot sp-dot--c"></span>
            <span class="sp-window-title">{t.board.window}</span>
          </div>

          <div class="sp-board">
            <div class="sp-board-row sp-board-row--head">
              <span>{t.board.cols.task}</span>
              <span>{t.board.cols.owner}</span>
              <span>{t.board.cols.status}</span>
              <span>{t.board.cols.date}</span>
            </div>

            {
              t.board.groups.map((g) => (
                <div class="sp-group">
                  <div class="sp-group-name">{g.name}</div>
                  {g.rows.map((row) => (
                    <div class="sp-board-row">
                      <span class="sp-cell-task">{row.task}</span>
                      <span class="sp-owner" aria-hidden="true">
                        {row.owner}
                      </span>
                      <span class={`sp-status sp-status--${row.statusKey}`}>{row.status}</span>
                      <span class="sp-date">{row.date}</span>
                    </div>
                  ))}
                </div>
              ))
            }

            <div class="sp-legend">
              <span class="sp-chip sp-chip--done">{t.board.legend.done}</span>
              <span class="sp-chip sp-chip--progress">{t.board.legend.progress}</span>
              <span class="sp-chip sp-chip--pending">{t.board.legend.pending}</span>
            </div>
          </div>

        </div>

        <figcaption class="sp-caption">{t.board.caption}</figcaption>
      </figure>
    </div>

    <!-- ============================ FLOWGRAM ============================ -->
    <div
      class="sp-panel"
      id="sp-panel-flowgram"
      role="tabpanel"
      aria-labelledby="sp-tab-flowgram"
      data-panel="flowgram"
      hidden
    >
      <figure class="sp-figure">
        <div class="sp-frame">
          <div class="sp-window">
            <span class="sp-dot sp-dot--a"></span>
            <span class="sp-dot sp-dot--b"></span>
            <span class="sp-dot sp-dot--c"></span>
            <span class="sp-window-title">{t.flowgram.window}</span>
          </div>

          <div class="sp-flow">
            <svg
              class="sp-flow-svg"
              viewBox="0 0 720 300"
              role="img"
              aria-label={t.flowgram.caption}
              preserveAspectRatio="xMidYMid meet"
            >
              <!-- connecting lines (logical mirroring handled by container scaleX in RTL) -->
              <g class="sp-flow-lines" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="150" y1="70" x2="230" y2="70" />
                <line x1="370" y1="70" x2="450" y2="70" />
                <path d="M540 95 L540 150 L300 150 L300 110" />
                <line x1="590" y1="95" x2="590" y2="220" />
              </g>

              <!-- nodes -->
              <g class="sp-flow-node" data-node="0">
                <rect x="20" y="44" width="130" height="52" rx="12" />
                <text x="85" y="74">{t.flowgram.nodes[0].label}</text>
              </g>
              <g class="sp-flow-node" data-node="1">
                <rect x="230" y="44" width="140" height="52" rx="12" />
                <text x="300" y="74">{t.flowgram.nodes[1].label}</text>
              </g>
              <g class="sp-flow-node sp-flow-node--decision" data-node="2">
                <rect x="450" y="44" width="180" height="52" rx="12" />
                <text x="540" y="74">{t.flowgram.nodes[2].label}</text>
              </g>
              <g class="sp-flow-node sp-flow-node--end" data-node="3">
                <rect x="520" y="220" width="140" height="52" rx="12" />
                <text x="590" y="250">{t.flowgram.nodes[3].label}</text>
              </g>

              <!-- branch labels -->
              <g class="sp-flow-branch">
                <text x="600" y="135" class="sp-flow-branch--yes">{t.flowgram.branchYes}</text>
                <text x="300" y="135" class="sp-flow-branch--no">{t.flowgram.branchNo}</text>
              </g>
            </svg>
          </div>

        </div>

        <figcaption class="sp-caption">{t.flowgram.caption}</figcaption>
      </figure>
    </div>

    <!-- ============================ TSM ============================ -->
    <div
      class="sp-panel"
      id="sp-panel-tsm"
      role="tabpanel"
      aria-labelledby="sp-tab-tsm"
      data-panel="tsm"
      hidden
    >
      <figure class="sp-figure">
        <div class="sp-frame">
          <div class="sp-window">
            <span class="sp-dot sp-dot--a"></span>
            <span class="sp-dot sp-dot--b"></span>
            <span class="sp-dot sp-dot--c"></span>
            <span class="sp-window-title">{t.tsm.window}</span>
            <span class="sp-live">
              <span class="sp-live-dot" aria-hidden="true"></span>
              {t.tsm.liveLabel}
            </span>
          </div>

          <div class="sp-dash">
            <div class="sp-kpis">
              {
                t.tsm.kpis.map((k) => (
                  <div class="sp-kpi">
                    <span class="sp-kpi-value">{k.value}</span>
                    <span class="sp-kpi-label">{k.label}</span>
                  </div>
                ))
              }
            </div>

            <div class="sp-dash-grid">
              <div class="sp-chart">
                <span class="sp-chart-title">{t.tsm.chartTitle}</span>
                <div class="sp-bars" role="img" aria-label={t.tsm.chartTitle}>
                  {ticketBars.map((h, i) => (
                    <span class="sp-bar" style={`--h:${h}%;--i:${i}`} />
                  ))}
                </div>
              </div>

              <div class="sp-tickets">
                <div class="sp-ticket-row sp-ticket-row--head">
                  <span>{t.tsm.cols.id}</span>
                  <span>{t.tsm.cols.title}</span>
                  <span>{t.tsm.cols.sev}</span>
                  <span>{t.tsm.cols.sla}</span>
                </div>
                {
                  t.tsm.tickets.map((tk) => (
                    <div class="sp-ticket-row">
                      <span class="sp-ticket-id">{tk.id}</span>
                      <span class="sp-ticket-title">{tk.title}</span>
                      <span class={`sp-sev sp-sev--${tk.sevKey}`}>{tk.sev}</span>
                      <span class="sp-ticket-sla">{tk.sla}</span>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>

        </div>

        <figcaption class="sp-caption">{t.tsm.caption}</figcaption>
      </figure>
    </div>

  </div>

  <div class="sp-live-region visually-hidden" aria-live="polite" aria-atomic="true" data-sp-live></div>
</section>

<style>
  .show-product {
    position: relative;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(82, 70, 217, 0.06) 18%,
      rgba(82, 70, 217, 0.04) 55%,
      transparent 100%
    );
  }

  .sp-head {
    max-width: var(--panel-max-wide);
    margin-inline: auto;
    text-align: center;
  }

  .sp-head .eyebrow {
    margin-block-start: var(--space-2);
  }

  .sp-head h2 {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl));
    margin-block-start: var(--space-3);
    letter-spacing: -0.03em;
  }

  .sp-lead {
    margin-block-start: var(--space-4);
    margin-inline: auto;
    max-inline-size: 52ch;
    color: var(--color-text-secondary);
    font-size: var(--text-md);
    line-height: var(--line-height-relaxed);
  }

  /* ---- Tabs ---- */
  .sp-tabs {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
    margin-block-start: var(--space-7);
    margin-inline: auto;
    max-inline-size: var(--content-max);
  }

  .sp-tab {
    appearance: none;
    border: 1px solid var(--color-border);
    background: var(--color-surface-raised);
    color: var(--color-text-secondary);
    font-weight: var(--font-weight-semibold);
    font-size: var(--text-sm);
    min-block-size: 44px;
    padding-block: var(--space-3);
    padding-inline: var(--space-5);
    border-radius: var(--radius-full);
    cursor: pointer;
    transition:
      color 0.22s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.22s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.22s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.22s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .sp-tab:hover {
    color: var(--color-text);
    border-color: var(--color-border-strong);
  }

  .sp-tab:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  .sp-tab[aria-selected='true'] {
    color: var(--color-surface-raised);
    background: var(--gradient-primary);
    border-color: transparent;
    box-shadow: var(--shadow-accent);
  }

  .sp-tab[aria-selected='true']:hover {
    color: var(--color-surface-raised);
    transform: none;
  }

  /* ---- Panels ---- */
  .sp-panel {
    margin-block-start: var(--space-7);
  }

  .sp-panel[hidden] {
    display: none;
  }

  /* Panel enter — same motion language as Hero + product demos */
  .sp-panel.is-entering .sp-frame {
    animation: sp-panel-in 0.35s var(--ease-out) forwards;
  }

  .sp-panel.is-entering[data-panel='tsm'] .sp-bar {
    transform: scaleY(1);
  }

  @keyframes sp-panel-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .sp-figure {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    max-width: var(--content-max);
    margin-inline: auto;
  }

  /* The product "screenshot" frame — the single raised surface for this region */
  .sp-frame {
    position: relative;
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .sp-frame::before {
    content: '';
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    block-size: 3px;
    background: var(--gradient-primary);
    opacity: 0.85;
    z-index: 1;
    pointer-events: none;
  }

  .sp-window {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding-block: var(--space-3);
    padding-inline: var(--space-4);
    background: var(--color-surface-muted);
    border-block-end: 1px solid var(--color-divider);
  }

  .sp-dot {
    width: 9px;
    height: 9px;
    border-radius: var(--radius-full);
    flex: none;
  }
  .sp-dot--a {
    background: var(--color-spark);
  }
  .sp-dot--b {
    background: var(--color-warning);
  }
  .sp-dot--c {
    background: var(--color-success);
  }

  .sp-window-title {
    margin-inline-start: var(--space-3);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sp-live {
    margin-inline-start: auto;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-muted);
    white-space: nowrap;
  }
  .sp-live-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background: var(--color-spark);
    box-shadow: 0 0 0 0 rgba(232, 93, 76, 0.45);
    animation: sp-live-pulse 2.4s var(--ease-out) infinite;
  }

  @keyframes sp-live-pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(232, 93, 76, 0.45);
    }
    70% {
      box-shadow: 0 0 0 8px rgba(232, 93, 76, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(232, 93, 76, 0);
    }
  }

  /* ---- monday board mock ---- */
  .sp-board {
    padding: var(--space-4);
    font-size: var(--text-sm);
  }

  .sp-board-row {
    display: grid;
    grid-template-columns: 1fr 40px 1.1fr 0.9fr;
    align-items: center;
    gap: var(--space-3);
    padding-block: var(--space-3);
    padding-inline: var(--space-3);
    border-block-end: 1px solid var(--color-divider);
  }

  .sp-board-row--head {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    border-block-end: 1px solid var(--color-border);
  }

  .sp-group {
    margin-block-start: var(--space-3);
  }

  .sp-group-name {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
    padding-inline-start: var(--space-3);
    margin-block-end: var(--space-1);
  }

  .sp-cell-task {
    color: var(--color-text);
    font-weight: var(--font-weight-medium);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sp-owner {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-full);
    background: var(--color-accent-soft);
    color: var(--color-accent);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
  }

  .sp-status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding-block: var(--space-1);
    padding-inline: var(--space-3);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    color: #fff;
    white-space: nowrap;
  }
  .sp-status--done {
    background: var(--color-success);
  }
  .sp-status--progress {
    background: var(--color-accent);
  }
  .sp-status--pending {
