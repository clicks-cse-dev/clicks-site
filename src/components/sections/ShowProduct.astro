  @media (max-width: 560px) {
    .sp-board-row {
      grid-template-columns: 1fr 32px 1fr;
    }
    .sp-board-row > .sp-date,
    .sp-board-row--head > span:last-child {
      display: none;
    }
    .sp-dash-grid {
      grid-template-columns: 1fr;
    }
    .sp-ticket-row {
      grid-template-columns: 0.6fr 1.6fr 0.8fr;
    }
    .sp-ticket-row > .sp-ticket-sla,
    .sp-ticket-row--head > span:last-child {
      display: none;
    }
