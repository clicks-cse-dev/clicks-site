  }

  .sp-date {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
  }

  .sp-legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-block-start: var(--space-4);
    padding-inline: var(--space-3);
  }
  .sp-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
  .sp-chip::before {
    content: '';
    width: 9px;
    height: 9px;
    border-radius: var(--radius-sm);
  }
  .sp-chip--done::before {
    background: var(--color-success);
  }
  .sp-chip--progress::before {
    background: var(--color-accent);
  }
  .sp-chip--pending::before {
    background: var(--color-warning);
  }

  /* ---- FlowGram mock (inline SVG, theme-driven) ---- */
  .sp-flow {
    padding: var(--space-5);
  }

  /* In RTL the diagram reads start->end naturally by horizontally mirroring;
     text inside is counter-flipped so labels stay legible. */
  :global([dir='rtl']) .sp-flow-svg {
    transform: scaleX(-1);
  }
  :global([dir='rtl']) .sp-flow-svg text {
    transform: scaleX(-1);
    transform-box: fill-box;
    transform-origin: center;
  }

  .sp-flow-lines {
    color: var(--color-brand-line);
    opacity: 0.7;
  }

  .sp-flow-node rect {
    fill: var(--color-surface-muted);
    stroke: var(--color-border-strong);
    stroke-width: 1.5;
  }
  .sp-flow-node text {
    fill: var(--color-text);
    font-size: 15px;
    font-weight: 600;
    text-anchor: middle;
    font-family: var(--font-sans);
  }
  .sp-flow-node--decision rect {
    fill: var(--color-accent-soft);
    stroke: var(--color-accent);
  }
  .sp-flow-node--decision text {
    fill: var(--color-accent-hover);
  }
  .sp-flow-node--end rect {
    fill: var(--color-success-soft);
    stroke: var(--color-success);
  }
  .sp-flow-node--end text {
    fill: var(--color-success);
  }

  .sp-flow-branch text {
    font-size: 12px;
    font-weight: 700;
    text-anchor: middle;
    font-family: var(--font-sans);
  }
  .sp-flow-branch--yes {
    fill: var(--color-success);
  }
  .sp-flow-branch--no {
    fill: var(--color-warning);
  }

  /* ---- Clicks TSM dashboard mock ---- */
  .sp-dash {
    padding: var(--space-4);
  }

  .sp-kpis {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .sp-kpi {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    background: var(--color-surface-muted);
    border: 1px solid var(--color-divider);
    text-align: start;
  }
  .sp-kpi-value {
    display: block;
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-extrabold);
    color: var(--color-accent-hover);
    line-height: var(--line-height-tight);
  }
  .sp-kpi-label {
    display: block;
    margin-block-start: var(--space-1);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .sp-dash-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: var(--space-3);
    margin-block-start: var(--space-3);
  }

  .sp-chart {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    background: var(--color-surface-muted);
    border: 1px solid var(--color-divider);
  }
  .sp-chart-title {
    display: block;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-muted);
    margin-block-end: var(--space-3);
  }
  .sp-bars {
    display: flex;
    align-items: flex-end;
    gap: var(--space-2);
    height: 96px;
  }
  .sp-bar {
    flex: 1;
    height: var(--h);
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    background: var(--gradient-primary);
    opacity: 0.85;
    transform: scaleY(0.35);
    transform-origin: bottom;
    transition: transform 0.55s var(--ease-out);
    transition-delay: calc(var(--i, 0) * 40ms);
  }


  .sp-tickets {
    padding: var(--space-2);
    border-radius: var(--radius-md);
    background: var(--color-surface-muted);
    border: 1px solid var(--color-divider);
    font-size: var(--text-xs);
  }
  .sp-ticket-row {
    display: grid;
    grid-template-columns: 0.6fr 1.6fr 0.8fr 0.7fr;
    align-items: center;
    gap: var(--space-2);
    padding-block: var(--space-2);
    padding-inline: var(--space-3);
    border-block-end: 1px solid var(--color-divider);
    border-radius: var(--radius-sm);
    transition:
      background var(--transition),
      box-shadow var(--transition);
  }
  .sp-ticket-row:last-child {
    border-block-end: none;
  }
  .sp-ticket-row--head {
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.03em;
