---
/**
 * Hero section (PRD §7 #2, §3 messaging, §5 brand).
 * Value-prop H1 (PRD §3 headline candidate #1) + subhead + ONE primary CTA
 * (BOOKING_URL) + monday.com certified-partner badge + an animated CSS/SVG
 * "ecosystem" centerpiece (Discover → Architect → Build → Operate).
 *
 * Contract: takes a `locale` prop; inline { he, en } content; scoped styles;
 * tokens only; RTL via logical properties; respects prefers-reduced-motion.
 */
import { Image } from 'astro:assets';
import type { Locale } from '../../i18n';
import { BOOKING_URL, MONDAY_PARTNER_BADGE_ALT } from '../../config';
import mondayPartnerBadge from '../../assets/monday-partner-badge.png';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const content = {
  he: {
    // PRD §3 headline candidate #3 — outcome framing (conversion + differentiation)
    title: 'בקשות, אישורים ודוחות שמתקדמים בלי לרדוף אחרי כולם.',
    titleAccentBefore: 'אפיון, בנייה ותחזוקה של תהליכים על ',
    titleAccentBrand: 'monday.com',
    titleAccentAfter: '.',
    subhead:
      'קליקס מלווה רשויות, גופים ציבוריים, מלכ״רים וארגונים תפעוליים בהפיכת תהליכים מפוזרים ללוחות monday.com שעובדים ביום־יום: אפיון, בנייה, חיבורים ותחזוקה שוטפת.',
    trustLine: 'מראים את המערכת עצמה, לא רק תהליך על שקף.',
    cta: 'לקביעת שיחת ייעוץ',
    ctaAria: 'לקביעת שיחת ייעוץ ביומן Google',
    diagramTitle: 'מהאפיון ועד התחזוקה',
    stepsLabel: 'שלבי העבודה',
    steps: ['אפיון', 'ארכיטקטורה', 'בנייה על monday', 'תפעול ותחזוקה'],
    stepViews: [
      {
        caption: 'ממפים צרכים, תהליכים ומדדים לפני שמתחילים לבנות.',
        variant: 'discover',
      },
      {
        caption: 'מתכננים לוחות, הרשאות וזרימות עבודה שאפשר לתחזק.',
        variant: 'architect',
      },
      {
        caption: 'בונים אוטומציות, חיבורים וסטטוסים ברורים על monday.com.',
        variant: 'build',
      },
      {
        caption: 'מטפלים בתמיכה, SLA ושינויים כדי שהמערכת תמשיך לעבוד.',
        variant: 'operate',
      },
    ],
    liveLabel: 'מערכת חיה',
  },
  en: {
    // PRD §3 headline candidate #3 (EN)
    title: 'Requests, approvals and reports that move without chasing everyone.',
    titleAccentBefore: 'Design, build and maintain workflows on ',
    titleAccentBrand: 'monday.com',
    titleAccentAfter: '.',
    subhead:
      'Clicks helps municipalities, public bodies, nonprofits and operations-heavy organizations turn scattered work into monday.com boards people actually use: discovery, build, integrations and ongoing care.',
    trustLine: 'We show the system itself, not just the process on a slide.',
    cta: 'Book a discovery call',
    ctaAria: 'Book a discovery call on Google Calendar',
    diagramTitle: 'From discovery to maintenance',
    stepsLabel: 'How we work',
    steps: ['Discover', 'Architect', 'Build on monday', 'Operate & maintain'],
    stepViews: [
      {
        caption: 'Map needs, processes and metrics before build starts.',
        variant: 'discover',
      },
      {
        caption: 'Plan boards, permissions and workflows that can be maintained.',
        variant: 'architect',
      },
      {
        caption: 'Build automations, integrations and clear statuses on monday.com.',
        variant: 'build',
      },
      {
        caption: 'Handle support, SLAs and changes so the system keeps working.',
        variant: 'operate',
      },
    ],
    liveLabel: 'Live system',
  },
} as const;

const t = content[locale];
---

<section class="section hero" aria-labelledby="hero-title">
  <div class="container hero__grid">
    <div class="hero__copy">
      <h1 id="hero-title" class="hero__title">
        <span class="hero__title-main">{t.title}</span>
        <span class="hero__title-accent">
          {t.titleAccentBefore}<span class="hero__monday">{t.titleAccentBrand}</span>{t.titleAccentAfter}
        </span>
      </h1>

      <p class="hero__subhead">{t.subhead}</p>
      <p class="hero__trust-mobile">{t.trustLine}</p>

      <div class="hero__actions">
        <a class="btn btn-primary hero__cta" href={BOOKING_URL} aria-label={t.ctaAria}>
          {t.cta}
          <svg class="hero__cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h13M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>

        <span class="hero__partner-wrap">
          <Image
            src={mondayPartnerBadge}
            alt={MONDAY_PARTNER_BADGE_ALT}
            class="hero__partner-badge"
            width={299}
            height={324}
            widths={[180, 260, 340]}
            loading="eager"
            decoding="async"
          />
        </span>
      </div>

      <p class="hero__trust">{t.trustLine}</p>
    </div>

    {/* Product centerpiece: methodology steps + monday board preview (no floating pills). */}
    <figure
      class="hero__viz"
      data-hero-viz
      data-captions={JSON.stringify(t.stepViews.map((v) => v.caption))}
      aria-label={t.diagramTitle}
    >
      <figcaption class="visually-hidden">{t.diagramTitle}</figcaption>

      <div class="hero__viz-head">
        <span class="hero__live">
          <span class="hero__live-dot" aria-hidden="true"></span>
          {t.liveLabel}
        </span>
      </div>

      <div class="hero__flow">
        <div class="hero__steps-wrap">
          <p class="hero__steps-label" id="hero-steps-label">{t.stepsLabel}</p>
          <ol class="hero__steps" role="tablist" aria-labelledby="hero-steps-label">
            {t.steps.map((label, i) => (
              <li role="presentation">
                <button
                  type="button"
                  class="hero__step"
                  role="tab"
                  id={`hero-step-${i}`}
                  aria-selected={i === 0 ? 'true' : 'false'}
                  aria-controls={`hero-panel-${i}`}
                  tabindex={i === 0 ? 0 : -1}
                  data-step={i}
                >
                  <span class="hero__step-num" aria-hidden="true">{i + 1}</span>
                  <span class="hero__step-label">{label}</span>
                </button>
              </li>
            ))}
          </ol>
        </div>

        <div class="hero__preview">
          <div class="hero__preview-chrome" aria-hidden="true">
            <span class="hero__preview-dot"></span>
            <span class="hero__preview-dot"></span>
            <span class="hero__preview-dot"></span>
          </div>

          <p class="hero__preview-caption" data-hero-caption aria-live="polite">
            {t.stepViews[0].caption}
          </p>

          <div class="hero__panels">
            {t.stepViews.map((view, i) => (
              <div
                class:list={['hero__panel', i === 0 && 'is-active']}
                id={`hero-panel-${i}`}
                role="tabpanel"
                aria-labelledby={`hero-step-${i}`}
                hidden={i !== 0}
                data-panel={i}
              >
                <div class="hero__board">
                  {view.variant === 'discover' && (
                    <div class="mndy-mock-table">
                      <div class="mndy-mock-header">
                        <span class="mndy-mock-title-text">{locale === 'he' ? 'מיפוי תהליכים קיימים' : 'Mapping Pains & Workflows'}</span>
                      </div>
                      <div class="mndy-mock-grid">
                        <div class="mndy-mock-row-item">
                          <span class="mndy-mock-row-title">📄 {locale === 'he' ? 'טפסים ידניים בנייר' : 'Paperwork Forms'}</span>
                          <span class="mndy-mock-badge-status mndy-badge-blue">{locale === 'he' ? 'מיפוי תהליך' : 'Process Map'}</span>
                        </div>
                        <div class="mndy-mock-row-item">
                          <span class="mndy-mock-row-title">✉️ {locale === 'he' ? 'מעקב מיילים מתיש' : 'Endless Email Chasing'}</span>
                          <span class="mndy-mock-badge-status mndy-badge-orange">{locale === 'he' ? 'אפיון שדות' : 'Fields Setup'}</span>
                        </div>
                        <div class="mndy-mock-row-item">
                          <span class="mndy-mock-row-title">📊 {locale === 'he' ? 'דוחות Excel ידניים' : 'Manual Reporting'}</span>
                          <span class="mndy-mock-badge-status mndy-badge-purple">{locale === 'he' ? 'הגדרת KPI' : 'Metrics Defined'}</span>
                        </div>
                      </div>
                    </div>
                  )}
                  {view.variant === 'architect' && (
                    <div class="mndy-mock-table">
                      <div class="mndy-mock-header">
                        <span class="mndy-mock-title-text">{locale === 'he' ? 'ארכיטקטורת המערכת' : 'System Architecture'}</span>
                      </div>
                      <div class="mndy-mock-grid">
                        <div class="mndy-mock-row-item">
                          <span class="mndy-mock-row-title">📂 {locale === 'he' ? 'תיקיית תפעול ורכש' : 'Operations Folder'}</span>
                          <span class="mndy-mock-badge-status mndy-badge-light">{locale === 'he' ? 'תיקייה' : 'Folder'}</span>
                        </div>
                        <div class="mndy-mock-row-item">
                          <span class="mndy-mock-row-title">📋 {locale === 'he' ? 'לוח פניות ומשימות' : 'Tasks Board'}</span>
                          <span class="mndy-mock-badge-status mndy-badge-light">{locale === 'he' ? 'לוח עבודה' : 'Board'}</span>
                        </div>
                        <div class="mndy-mock-row-item">
                          <span class="mndy-mock-row-title">⚙️ {locale === 'he' ? 'מבנה עמודות וציר זמן' : 'Columns Layout'}</span>
                          <span class="mndy-mock-badge-status mndy-badge-light">{locale === 'he' ? 'שדות מערכת' : 'Columns Schema'}</span>
                        </div>
                      </div>
                    </div>
                  )}
                  {view.variant === 'build' && (
                    <div class="mndy-mock-table">
                      <div class="mndy-mock-header">
                        <span class="mndy-mock-title-text">{locale === 'he' ? 'בנייה ואוטומציות' : 'Build & Automations'}</span>
                      </div>
                      <div class="mndy-mock-automation-bubble">
                        <span class="mndy-mock-automation-icon" aria-hidden="true">⚡</span>
                        <span class="mndy-mock-automation-text">
                          {locale === 'he' 
                            ? 'כאשר סטטוס משתנה ל-אושר ➔ שלח אימייל ועדכן אחראי' 
                            : 'When Status changes to Approved ➔ send Email & update Owner'}
                        </span>
                      </div>
                      <div class="mndy-mock-grid">
                        <div class="mndy-mock-row-item">
                          <span class="mndy-mock-row-title">💰 {locale === 'he' ? 'בקשת תקציב מחלקה' : 'Dept Budget Request'}</span>
                          <span class="mndy-mock-badge-status mndy-badge-green">{locale === 'he' ? 'אושר אוטומטית' : 'Auto Approved'}</span>
                        </div>
                        <div class="mndy-mock-row-item">
                          <span class="mndy-mock-row-title">📱 {locale === 'he' ? 'הודעת WhatsApp נכנסת' : 'WhatsApp Msg'}</span>
                          <span class="mndy-mock-badge-status mndy-badge-green">{locale === 'he' ? 'בוצע' : 'Done'}</span>
                        </div>
                      </div>
                    </div>
                  )}
                  {view.variant === 'operate' && (
                    <div class="mndy-mock-table">
                      <div class="mndy-mock-header">
                        <span class="mndy-mock-title-text">{locale === 'he' ? 'תפעול שוטף ו-SLA' : 'Ongoing Care & SLA'}</span>
                      </div>
                      <div class="mndy-mock-grid">
                        <div class="mndy-mock-row-item">
                          <span class="mndy-mock-row-title">🎫 {locale === 'he' ? 'קריאת תמיכה דחופה' : 'Critical SLA Ticket'}</span>
                          <span class="mndy-mock-badge-status mndy-badge-amber">{locale === 'he' ? 'בטיפול' : 'In Progress'}</span>
                        </div>
                        <div class="mndy-mock-row-item">
                          <span class="mndy-mock-row-title">🔧 {locale === 'he' ? 'שינוי הרשאות משתמש' : 'Permissions Update'}</span>
                          <span class="mndy-mock-badge-status mndy-badge-green">{locale === 'he' ? 'הושלם' : 'Done'}</span>
                        </div>
                        <div class="mndy-mock-row-item">
                          <span class="mndy-mock-row-title">🔗 {locale === 'he' ? 'סנכרון API חיצוני' : 'API Sync Check'}</span>
                          <span class="mndy-mock-badge-status mndy-badge-blue">{locale === 'he' ? 'תקין' : 'Active'}</span>
                        </div>
                      </div>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </figure>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow-x: clip;
    overflow-y: visible;
    padding-block: var(--space-6) var(--space-9);
  }

  .hero__grid > * {
    min-inline-size: 0;
  }

  /* Soft glow sits behind the viz column, not under the header. */
  .hero::before {
    content: '';
    position: absolute;
    inset-block-start: 12%;
    inset-inline-start: -6%;
    inline-size: min(36rem, 55%);
    block-size: 28rem;
    background: var(--gradient-soft);
    filter: blur(56px);
    border-radius: var(--radius-full);
    opacity: 0.55;
    z-index: 0;
    pointer-events: none;
  }

  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    gap: var(--space-8);
    align-items: center;
  }

  /* ---- Copy column ---- */
  .hero__copy {
    max-inline-size: var(--panel-max-wide);
  }

  .hero__title {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-inline-size: 20ch;
    text-wrap: balance;
  }

  .hero__title-main {
    font-size: clamp(1.85rem, 4.2vw, 3rem);
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: var(--color-text);
    min-block-size: 2.2em;
  }

  /* Accent line: solid ink; underline only under monday.com (DESIGN.md: no gradient text). */
  .hero__title-accent {
    font-size: clamp(var(--text-lg), 2.6vw, var(--text-2xl));
    line-height: var(--line-height-snug);
    letter-spacing: -0.02em;
    color: var(--color-accent-hover);
    max-inline-size: 26ch;
  }
  .hero__monday {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }
  .hero__monday::after {
    content: '';
    position: absolute;
    inset-inline: 0;
    inset-block-end: 0.05em;
    block-size: 0.11em;
    background: var(--gradient-primary);
    border-radius: var(--radius-full);
    opacity: 0.6;
  }

  .hero__subhead {
    margin-block-start: var(--space-4);
    max-inline-size: 40ch;
    font-size: var(--text-base);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
  }

  .hero__actions {
    margin-block-start: var(--space-5);
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    gap: var(--space-4);
  }

  .hero__trust {
    margin-block-start: var(--space-5);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    max-inline-size: 36ch;
  }
  .hero__trust::before {
    content: '';
    display: inline-block;
    inline-size: 6px;
    block-size: 6px;
    margin-inline-end: var(--space-2);
    border-radius: var(--radius-full);
    background: var(--color-spark);
    vertical-align: middle;
  }

  @media (max-width: 640px) {
    .hero__actions {
      flex-direction: row;
      flex-wrap: nowrap;
      align-items: center;
      gap: var(--space-3);
    }
    .hero__cta {
      flex: 1 1 auto;
      min-inline-size: 0;
      justify-content: center;
      padding-block: var(--space-3);
      padding-inline: var(--space-4);
      font-size: var(--text-base);
    }
    .hero__partner-wrap {
      flex-shrink: 0;
    }
    /* Cap to roughly the CTA pill height so the hexagon sits flush, not poking out. */
    .hero__partner-badge {
      height: 2.9rem;
      margin-inline: 0;
    }
    .hero__trust {
      display: none;
    }
  }

  .hero__trust-mobile {
    display: none;
    margin-block-start: var(--space-3);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-muted);
    line-height: var(--line-height-snug);
  }

  .hero__trust-mobile::before {
    content: '';
    display: inline-block;
    inline-size: 6px;
    block-size: 6px;
    margin-inline-end: var(--space-2);
    border-radius: var(--radius-full);
    background: var(--color-spark);
    vertical-align: middle;
  }

  @media (max-width: 640px) {
    .hero__trust-mobile {
      display: block;
    }
  }

  .hero__cta {
    font-size: var(--text-md);
    padding-block: var(--space-4);
    padding-inline: var(--space-6);
  }
  .hero__cta-arrow {
    transition: transform var(--transition);
  }
  /* Mirror the arrow in RTL so it points "forward". */
  :global([dir='rtl']) .hero__cta-arrow {
    transform: scaleX(-1);
  }
  .hero__cta:hover .hero__cta-arrow {
    transform: translateX(2px);
  }
  :global([dir='rtl']) .hero__cta:hover .hero__cta-arrow {
    transform: scaleX(-1) translateX(2px);
  }

  /* monday.com Certified Partner hex badge (official asset, transparent matte). */
  .hero__partner-wrap {
    display: inline-flex;
    align-items: center;
    align-self: center;
    flex-shrink: 0;
    line-height: 0;
    background: transparent;
  }
  .hero__partner-badge {
    display: block;
    height: 5rem;
    width: auto;
    aspect-ratio: 299 / 324;
    object-fit: contain;
    object-position: center;
    image-rendering: -webkit-optimize-contrast;
  }
  @media (min-width: 768px) {
    .hero__partner-badge {
      height: 5.75rem;
    }
  }

  /* ============================================================
     Centerpiece — steps + board preview
     ============================================================ */
  .hero__viz {
    margin: 0;
    padding: var(--space-5);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    min-block-size: 20rem;
    max-block-size: min(34rem, 78vh);
  }

  .hero__viz-head {
    display: flex;
    justify-content: flex-start;
    margin-block-end: var(--space-4);
  }
  .hero__live {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .hero__live-dot {
    inline-size: 8px;
    block-size: 8px;
    border-radius: var(--radius-full);
    background: var(--color-spark);
    box-shadow: 0 0 0 0 var(--color-spark);
    animation: heroPulse 2.4s var(--ease-out) infinite;
  }

  .hero__flow {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: stretch;
  }
  @media (min-width: 520px) {
    .hero__flow {
      grid-template-columns: 0.95fr 1.1fr;
      gap: var(--space-6);
    }
  }

  @media (min-width: 1024px) {
    .hero__flow {
      gap: var(--space-7);
    }
  }

  .hero__steps-label {
    margin: 0 0 var(--space-3);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }
  .hero__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .hero__steps > li {
    margin: 0;
  }
  .hero__step {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    width: 100%;
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-xs);
    font: inherit;
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    line-height: 1.25;
    text-align: start;
    cursor: pointer;
    transition:
      border-color var(--transition),
      background var(--transition),
      box-shadow var(--transition);
  }
  .hero__step:hover {
    border-color: var(--color-border-strong);
    background: var(--color-surface-raised);
  }
  .hero__step[aria-selected='true'] {
    border-color: var(--color-accent);
    background: var(--color-accent-muted);
    box-shadow: var(--shadow-sm);
  }
  .hero__step:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }
  .hero__step-num {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    inline-size: 2rem;
    block-size: 2rem;
    border-radius: var(--radius-full);
    background: var(--gradient-primary);
    color: #fff;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
  }
  .hero__step-label {
    flex: 1;
    min-width: 0;
  }

  .hero__preview {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
