  /* Respect reduced motion (PRD §10, DESIGN.md). */
  @media (prefers-reduced-motion: reduce) {
    .hero__live-dot,
    .hero__panel,
    .hero__panel.is-active {
      animation: none;
    }
    .hero__step {
      transition: none;
    }
    .hero__copy > *,
    .hero__viz {
      animation: none;
      transform: none;
    }
    .hero__cta-arrow,
    .hero__cta:hover .hero__cta-arrow {
      transition: none;
    }
  }
</style>

<script>
  const roots = document.querySelectorAll<HTMLElement>('[data-hero-viz]');

  roots.forEach((root) => {
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[role="tab"][data-step]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-panel]'));
    const captionEl = root.querySelector<HTMLElement>('[data-hero-caption]');
    let captions: string[] = [];
    try {
      captions = JSON.parse(root.dataset.captions ?? '[]');
    } catch {
      captions = [];
    }

    if (!tabs.length || !panels.length) return;

    let active = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const intervalMs = 4500;

    const activate = (index: number, focusTab = false) => {
      const i = ((index % tabs.length) + tabs.length) % tabs.length;
      active = i;

      tabs.forEach((tab, ti) => {
        const on = ti === i;
        tab.setAttribute('aria-selected', on ? 'true' : 'false');
        tab.tabIndex = on ? 0 : -1;
      });

      panels.forEach((panel, pi) => {
        const on = pi === i;
        panel.hidden = !on;
        panel.classList.toggle('is-active', on);
      });

      if (captionEl && captions[i]) captionEl.textContent = captions[i];
      if (focusTab) tabs[i]?.focus();
    };

    const stopAuto = () => {
      if (timer) {
        clearInterval(timer);
        timer = null;
      }
    };

    const startAuto = () => {
      stopAuto();
      if (reduceMotion || tabs.length < 2) return;
      timer = setInterval(() => activate(active + 1), intervalMs);
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => {
        activate(i);
        stopAuto();
      });
      tab.addEventListener('keydown', (e) => {
        if (e.key !== 'ArrowDown' && e.key !== 'ArrowUp') return;
        e.preventDefault();
        const next =
          e.key === 'ArrowDown'
            ? (i + 1) % tabs.length
            : (i - 1 + tabs.length) % tabs.length;
        activate(next, true);
        stopAuto();
      });
    });

    root.addEventListener('mouseenter', stopAuto);
    root.addEventListener('mouseleave', startAuto);
    root.addEventListener('focusin', stopAuto);
    root.addEventListener('focusout', (e) => {
      if (!root.contains(e.relatedTarget as Node)) startAuto();
    });

    activate(0);
    startAuto();
  });
</script>
