  .mndy-mock-automation-icon {
    font-size: var(--text-sm);
    animation: pulseZap 1.8s ease-in-out infinite;
  }
  .mndy-mock-automation-text {
    color: var(--color-accent);
    font-weight: var(--font-weight-semibold);
  }
  @keyframes pulseZap {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.15); opacity: 1; }
  }

  /* ============================================================ */
     Motion keyframes
     ============================================================ */
  @keyframes heroPulse {
    0%   { box-shadow: 0 0 0 0 rgba(232, 93, 76, 0.5); }
    70%  { box-shadow: 0 0 0 8px rgba(232, 93, 76, 0); }
    100% { box-shadow: 0 0 0 0 rgba(232, 93, 76, 0); }
  }
  @keyframes heroPanelIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: none; }
  }
  /* Entrance: transform only so content stays visible if animation is skipped */
  .hero__copy > *,
  .hero__viz {
    transform: translateY(10px);
    animation: heroReveal 0.7s var(--ease-out) forwards;
  }
  .hero__copy > :nth-child(1) { animation-delay: 0.05s; }
  .hero__copy > :nth-child(2) { animation-delay: 0.12s; }
  .hero__copy > :nth-child(3) { animation-delay: 0.19s; }
  .hero__copy > :nth-child(4) { animation-delay: 0.24s; }
  .hero__copy > :nth-child(5) { animation-delay: 0.3s; }
  .hero__viz { animation-delay: 0.2s; }

  @keyframes heroReveal {
    to { transform: none; }
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .hero__grid {
      grid-template-columns: 1fr;
