  .mndy-badge-blue { background: #0085ff; }
  .mndy-badge-orange { background: #ff642e; }
  .mndy-badge-purple { background: #784bd1; }
  .mndy-badge-green { background: #00c875; }
  .mndy-badge-amber { background: #ffcb00; color: #323338; }
  .mndy-badge-light { background: var(--color-border-strong); color: var(--color-text); }

  .mndy-mock-automation-bubble {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background: linear-gradient(135deg, rgba(82, 70, 217, 0.08) 0%, rgba(108, 93, 235, 0.08) 100%);
    border: 1px solid rgba(82, 70, 217, 0.22);
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-3);
    margin-block-end: var(--space-3);
