---
/**
 * Methodology section (PRD §7 #4).
 * The 4-step operating model: Discover -> Architect -> Build on monday -> Operate (Clicks TSM),
 * rendered as a horizontal flow with a connecting line, numbered nodes and scroll-reveal.
 * Conventions: locale prop + inline bilingual content; tokens + logical properties only;
 * scoped styles; inline theme-driven SVG (currentColor); respects prefers-reduced-motion.
 */
import type { Locale } from '../../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const content = {
  he: {
    title: 'ממה שהארגון צריך ועד מערכת שעובדת — בארבעה שלבים',
    lead:
      'לא נעלמים אחרי מצגת. נשארים מההתחלה: להבין מה באמת צריך, לתכנן ולבנות ב‑monday.com, ולתחזק ולשפר כשהצוות כבר עובד במערכת.',
    steps: [
      {
        title: 'גילוי',
        sub: 'להבין לפני שבונים',
        body:
          'פגישות עם האנשים הרלוונטיים, מיפוי איך העבודה נעשת היום, מה מציק ומה נחשב להצלחה — לפני שפותחים לוח או בונים אוטומציה.',
      },
      {
        title: 'אפיון',
        sub: 'תכנון התהליך',
        body:
          'מסדרים מי עושה מה ובאיזה שלב, מה יקרה אוטומטית ומה יתחבר למערכות שכבר יש לכם. ב‑FlowGram אפשר לראות את התמונה המלאה לפני הבנייה.',
      },
      {
        title: 'בנייה על monday',
        sub: 'המערכת עולה לאוויר',
        body:
          'מקימים את העבודה ב‑monday.com — לוחות, מעקב אחרי פניות ולקוחות, תוכן ומפות כשצריך, וחיבור למערכות קיימות. משהו שאנשים באמת משתמשים בו, לא הדגמה.',
      },
      {
        title: 'תפעול',
        sub: 'תחזוקה עם Clicks TSM',
        body:
          'אחרי ההשקה: תמיכה, טיפול בתקלות, עדכונים ושיפורים — כדי שהמערכת תמשיך להתאים לארגון ולא תישאר מאחור.',
      },
    ],
    footnote: 'זה לא נגמר בשלב הרביעי — לומדים ממה שקורה בשטח ומשפרים בכל מחזור.',
  },
  en: {
    title: 'From what you need to a system that works — in four steps',
    lead:
      "We don't disappear after a slide deck. We stay from the start: understand what's actually needed, plan and build on monday.com, then maintain and improve once your team is using it day to day.",
    steps: [
      {
        title: 'Discover',
        sub: 'Understand before you build',
        body:
          "Meet the people involved, map how work happens today, what's painful and what counts as success — before opening a board or wiring an automation.",
      },
      {
        title: 'Architect',
        sub: 'Plan the process',
        body:
          'Clarify who does what at each step, what should run automatically and what should connect to systems you already have. FlowGram helps lay out the full picture before we build.',
      },
      {
        title: 'Build on monday',
        sub: 'Go live on monday.com',
        body:
          'Set up the work on monday.com — boards, tracking requests and customers, content and maps when needed, and hooks to your existing tools. Something people actually use, not a demo.',
      },
      {
        title: 'Operate',
        sub: 'Ongoing support with Clicks TSM',
        body:
          'After launch: help desk, fixes, updates and improvements — so the system keeps fitting the organization instead of falling behind.',
      },
    ],
    footnote: "It doesn't end at step four — we learn from what's happening in the field and improve each cycle.",
  },
} as const;

const t = content[locale];

// Theme-driven inline SVG icons (currentColor), one per step.
const icons = [
  // Discover — magnifier over nodes
  '<circle cx="11" cy="11" r="6.2"/><line x1="15.6" y1="15.6" x2="21" y2="21"/><circle cx="11" cy="11" r="1.6" fill="currentColor" stroke="none"/>',
  // Architect — blueprint / flow blocks
  '<rect x="3" y="4" width="7" height="6" rx="1.4"/><rect x="14" y="4" width="7" height="6" rx="1.4"/><rect x="8.5" y="15" width="7" height="6" rx="1.4"/><path d="M6.5 10v2.5h11V10M12 12.5V15"/>',
  // Build on monday — stacked board lanes
  '<rect x="3" y="4" width="18" height="16" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="9" x2="9" y2="20"/><line x1="15" y1="9" x2="15" y2="20"/>',
  // Operate — gear / continuous run
  '<circle cx="12" cy="12" r="3.2"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M18.4 5.6l-2.1 2.1M7.7 16.3l-2.1 2.1"/>',
];
---

<section class="section methodology" aria-labelledby="methodology-title">
  <div class="container">
    <header class="methodology__head">
      <h2 id="methodology-title">{t.title}</h2>
      <p class="methodology__lead">{t.lead}</p>
    </header>

    <ol class="flow" role="list">
      {
        t.steps.map((step, i) => (
          <li class="flow__step" style={`--step-index:${i};`}>
            <div class="flow__node">
              <span class="flow__num" aria-hidden="true">{i + 1}</span>
              <span class="flow__icon" aria-hidden="true">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={icons[i]}
                />
              </span>
            </div>
            <div class="flow__body">
              <h3 class="flow__title">{step.title}</h3>
              <p class="flow__sub">{step.sub}</p>
              <p class="flow__text">{step.body}</p>
            </div>
          </li>
        ))
      }
    </ol>

    <p class="methodology__footnote">
      <span class="methodology__dot" aria-hidden="true"></span>
      {t.footnote}
    </p>
  </div>
</section>

<style>
  .methodology {
    overflow: clip;
  }

  .methodology__head {
    max-width: var(--panel-max-wide);
    margin-block-end: var(--space-8);
  }

  .methodology__head h2 {
    font-size: var(--text-3xl);
    margin-block: var(--space-3) var(--space-4);
  }

  .methodology__lead {
    font-size: var(--text-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
  }

  /* ---- Horizontal flow with connecting line ---- */
  .flow {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
    position: relative;
  }

  /* The connecting line runs through the row of nodes. */
  .flow::before {
    content: '';
    position: absolute;
    inset-block-start: 28px; /* center of the 56px node */
    inset-inline: 7%;
    block-size: 2px;
    background: linear-gradient(
      to right,
      var(--color-brand-line),
      var(--color-brand-violet)
    );
    opacity: 0.5;
    z-index: 0;
  }

  .flow__step {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transform: translateY(16px);
    animation: flow-reveal 0.6s var(--ease-out) forwards;
    animation-delay: calc(var(--step-index) * 0.12s);
  }

  .flow__node {
    position: relative;
    inline-size: 56px;
    block-size: 56px;
    border-radius: var(--radius-full);
    background: var(--gradient-primary);
    box-shadow: var(--shadow-accent);
    color: #fff;
    display: grid;
    place-items: center;
  }

  .flow__icon svg {
    inline-size: 26px;
    block-size: 26px;
  }

  /* Numbered badge sits on the outer-start corner of the node. */
  .flow__num {
    position: absolute;
    inset-block-start: -8px;
    inset-inline-start: -8px;
    inline-size: 24px;
    block-size: 24px;
    border-radius: var(--radius-full);
    background: var(--color-surface-raised);
    color: var(--color-accent);
    border: 1px solid var(--color-border-strong);
    box-shadow: var(--shadow-xs);
    display: grid;
    place-items: center;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    line-height: 1;
  }

  .flow__title {
    font-size: var(--text-lg);
    margin-block-end: var(--space-1);
  }

  .flow__sub {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.02em;
    color: var(--color-accent);
    margin-block-end: var(--space-3);
  }

  .flow__text {
    font-size: var(--text-base);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
  }

  /* ---- Living-cycle footnote ---- */
  .methodology__footnote {
    margin-block-start: var(--space-8);
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .methodology__dot {
    inline-size: 9px;
    block-size: 9px;
    border-radius: var(--radius-full);
    background: var(--color-spark);
    box-shadow: 0 0 0 4px var(--color-accent-muted);
    animation: pulse-dot 2.4s var(--ease-out) infinite;
  }

  @keyframes flow-reveal {
    to {
      transform: translateY(0);
    }
  }

  @keyframes pulse-dot {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.35);
      opacity: 0.7;
    }
  }

  /* ---- Responsive: stack into a vertical flow on narrow screens ---- */
  @media (max-width: 880px) {
    .flow {
      grid-template-columns: 1fr;
      gap: var(--space-7);
    }

    /* Vertical connecting line through the column of nodes. */
    .flow::before {
      inset-block: 28px;
      inset-inline-start: 27px; /* center of the 56px node */
      inline-size: 2px;
      block-size: auto;
      background: linear-gradient(
        to bottom,
        var(--color-brand-line),
        var(--color-brand-violet)
      );
    }

    .flow__step {
      flex-direction: row;
      align-items: flex-start;
    }

    .flow__node {
      flex: none;
    }
  }

  @media (max-width: 640px) {
    .methodology__head h2 {
      font-size: var(--text-2xl);
    }
  }

  /* ---- Respect reduced motion: no transforms/loops, content visible ---- */
  @media (prefers-reduced-motion: reduce) {
    .flow__step {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .methodology__dot {
      animation: none;
    }
  }
</style>
