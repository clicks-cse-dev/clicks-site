---
/**
 * ProductsFamily — products (CMS, GIS) vs custom-development services on monday.com.
 * Products: CMS, GIS, deploy ready — services: FlowGram, TSM, CRM, Solutions.
 */
import type { Locale } from '../../i18n';
import { localizedPath } from '../../i18n';
import ProductCardLogo from '../product-logos/ProductCardLogo.astro';
import { offerPagePath } from '../../data/productPages';
import type { ProductKey, ServiceKey } from '../product-logos/types';
import '../product-logos/ProductLockup.css';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type CardItem = { name: string; oneLiner: string; href: string };

const content = {
  he: {
    title: 'מוצרים ופיתוחים מותאמים על monday.com',
    intro:
      'מוצרים מוכנים ופיתוח מותאם: ניהול תוכן, מפות, חבילות מוכנות להטמעה, תכנון תהליכים, תחזוקה וחיבורי CRM לארגונים ציבוריים, אזרחיים ותפעוליים.',
    productsLabel: 'מוצרים',
    servicesLabel: 'פיתוחים מותאמים',
    products: {
      cms: {
        name: 'Clicks Monday CMS',
        oneLiner:
          'ניהול תוכן ל-monday.com — סנכרון קטלוג ותוכן עסקי, והנעת אתרים ואפליקציות ישירות מלוחות monday.',
        href: offerPagePath('monday-cms'),
      },
      gis: {
        name: 'Clicks Monday GIS',
        oneLiner:
          'סנכרון דו-כיווני בין monday.com ל-ArcGIS דרך GeoJSON; הטמעת GIS בתצוגות לוח ופריט ומפות משופרות.',
        href: offerPagePath('monday-gis'),
      },
      ready: {
        name: 'Clicks deploy ready',
        oneLiner:
          'חבילות monday מוכנות להטמעה: CRM 360, ניהול תיקים, קליטה, SLA ודשבורדים.',
        href: offerPagePath('clicks-deploy-ready'),
      },
    } satisfies Record<ProductKey, CardItem>,
    services: {
      flowgram: {
        name: 'FlowGram by Clicks',
        oneLiner:
          'תכנון תהליכים: מפת עבודה, אוטומציות וחיבורים בין מערכות לפני הבנייה על monday.',
        href: offerPagePath('flowgram'),
      },
      tsm: {
        name: 'Clicks TSM',
        oneLiner:
          'תחזוקה שוטפת למערכות monday: קריאות שירות, הרשאות, דוחות, SLA ושינויים.',
        href: offerPagePath('clicks-tsm'),
      },
      crm: {
        name: 'Clicks CRM Connections',
        oneLiner:
          'תקשורת רב-ערוצית על monday.com (WhatsApp Business, Meta Messenger, אימייל) לקליטת לידים, טיפוח וניתוב.',
        href: offerPagePath('crm-connections'),
      },
      solutions: {
        name: 'Clicks Solutions',
        oneLiner:
          'פיתוח מותאם על monday.com — לוחות, אוטומציות, אינטגרציות וממשקים לפי אפיון הארגון, מגילוי ועד תחזוקה.',
        href: offerPagePath('clicks-solutions'),
      },
    } satisfies Record<ServiceKey, CardItem>,
    cardCta: 'גלו עוד',
    roadmap: {
      chip: 'מתוכנן ל-2027',
      name: 'Clicks WORK',
      oneLiner:
        'ניהול שינוי ותהליכי עבודה פנים-ארגוניים. מתוכנן ל-2027.',
    },
  },
  en: {
    title: 'Products and custom builds on monday.com',
    intro:
      'Ready products and custom development: content management, maps, ready implementation packs, process planning, maintenance and CRM connections for public, civic and operations-heavy organizations.',
    productsLabel: 'Products',
    servicesLabel: 'Custom developments',
    products: {
      cms: {
        name: 'Clicks Monday CMS',
        oneLiner:
          'Content management for monday.com — sync catalog & business content, and power websites and apps from monday boards.',
        href: offerPagePath('monday-cms'),
      },
      gis: {
        name: 'Clicks Monday GIS',
        oneLiner:
          'Bi-directional monday.com ↔ ArcGIS sync via GeoJSON; GIS embedded in board & item views, plus enhanced Maps.',
        href: offerPagePath('monday-gis'),
      },
      ready: {
        name: 'Clicks deploy ready',
        oneLiner:
          'Ready monday implementation packs: CRM 360, case management, intake, SLA and dashboards.',
        href: offerPagePath('clicks-deploy-ready'),
      },
    } satisfies Record<ProductKey, CardItem>,
    services: {
      flowgram: {
        name: 'FlowGram by Clicks',
        oneLiner:
          'Process planning: work map, automations and system connections before the monday build.',
        href: offerPagePath('flowgram'),
      },
      tsm: {
        name: 'Clicks TSM',
        oneLiner:
          'Ongoing care for monday systems: service tickets, permissions, reports, SLAs and changes.',
        href: offerPagePath('clicks-tsm'),
      },
      crm: {
        name: 'Clicks CRM Connections',
        oneLiner:
          'Multi-channel comms on monday.com (WhatsApp Business, Meta Messenger, email) for lead intake, nurture and routing.',
        href: offerPagePath('crm-connections'),
      },
      solutions: {
        name: 'Clicks Solutions',
        oneLiner:
          'Bespoke monday.com builds — boards, automations, integrations and interfaces from discovery through maintenance.',
        href: offerPagePath('clicks-solutions'),
      },
    } satisfies Record<ServiceKey, CardItem>,
    cardCta: 'Learn more',
    roadmap: {
      chip: '2027 · on the roadmap',
      name: 'Clicks WORK',
      oneLiner:
        'Change management and internal work processes. Planned for 2027.',
    },
  },
} as const;

const t = content[locale];
const productOrder: ProductKey[] = ['cms', 'gis', 'ready'];
const serviceOrder: ServiceKey[] = ['flowgram', 'tsm', 'crm', 'solutions'];
---

<section class="section products" aria-labelledby="products-family-title">
  <div class="container">
    <header class="products__head" data-reveal>
      <h2 id="products-family-title" class="products__title">{t.title}</h2>
      <p class="products__intro">{t.intro}</p>
    </header>

    <div class="products__lane" data-reveal>
      <h3 class="products__lane-title">{t.productsLabel}</h3>
      <ul class="products__grid products__grid--products" role="list">
        {
          productOrder.map((key, i) => {
            const p = t.products[key];
            return (
              <li class="products__item" data-reveal style={`--reveal-delay:${i * 60}ms`}>
                <a class="card product-card" href={localizedPath(p.href, locale)} aria-label={p.name}>
                  <div class="product-card__logo">
                    <ProductCardLogo product={key} label={p.name} />
                  </div>
                  <p class="product-card__line">{p.oneLiner}</p>
                  <span class="product-card__cta">
                    {t.cardCta}
                    <svg
                      class="product-card__arrow"
                      viewBox="0 0 16 16"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M3 8h9" />
                      <path d="M8 4l4 4-4 4" />
                    </svg>
                  </span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>

    <div class="products__lane" data-reveal>
      <h3 class="products__lane-title">{t.servicesLabel}</h3>
      <ul class="products__grid products__grid--services" role="list">
        {
          serviceOrder.map((key, i) => {
            const p = t.services[key];
            return (
              <li class="products__item" data-reveal style={`--reveal-delay:${120 + i * 60}ms`}>
                <a class="card product-card" href={localizedPath(p.href, locale)} aria-label={p.name}>
                  <div class="product-card__logo">
                    <ProductCardLogo product={key} label={p.name} />
                  </div>
                  <p class="product-card__line">{p.oneLiner}</p>
                  <span class="product-card__cta">
                    {t.cardCta}
                    <svg
                      class="product-card__arrow"
                      viewBox="0 0 16 16"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M3 8h9" />
                      <path d="M8 4l4 4-4 4" />
                    </svg>
                  </span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>

    <div class="products__roadmap" data-reveal>
      <span class="roadmap-chip" aria-hidden="true">
        <span class="roadmap-chip__dot"></span>
        {t.roadmap.chip}
      </span>
      <p class="roadmap-text">
        <strong>{t.roadmap.name}</strong>
        <span>{t.roadmap.oneLiner}</span>
      </p>
    </div>
  </div>
</section>

<style>
  .products {
    background:
      radial-gradient(ellipse 60% 40% at 100% 0%, var(--color-accent-muted), transparent 60%),
      transparent;
  }

  .products__head {
    max-width: var(--panel-max-wide);
    margin-block-end: var(--space-8);
  }

  .products__title {
    font-size: var(--text-3xl);
    margin-block: var(--space-3) var(--space-4);
  }

  .products__intro {
    color: var(--color-text-secondary);
    font-size: var(--text-md);
    line-height: var(--line-height-relaxed);
    text-align: start;
  }

  .products__lane {
    margin-block-end: var(--space-8);
  }

  .products__lane-title {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin-block: 0 var(--space-4);
  }

  .products__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-5);
  }

  .products__grid--products {
    grid-template-columns: repeat(3, 1fr);
  }

  @media (max-width: 960px) {
    .products__grid--products {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .products__grid--services {
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 960px) {
    .products__grid--services {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .products__item {
    display: flex;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
    inline-size: 100%;
    color: var(--color-text);
    transition:
      transform var(--duration-spring) var(--ease-spring),
      box-shadow var(--duration-spring) var(--ease-spring),
      border-color var(--duration-normal) var(--ease-smooth);
  }

  .product-card:hover,
  .product-card:focus-visible {
    color: var(--color-text);
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-border-strong);
  }

  .product-card__logo {
    display: flex;
    align-items: flex-start;
    min-block-size: 3.75rem;
    margin-block-end: var(--space-3);
  }

  .product-card__logo :global(.product-lockup) {
    flex-wrap: nowrap;
    width: 100%;
  }

  .product-card__line {
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    line-height: var(--line-height-relaxed);
    margin-block-end: var(--space-3);
  }

  .product-card__cta {
    margin-block-start: auto;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-accent);
  }

  .product-card__arrow {
    inline-size: 15px;
    block-size: 15px;
    transition: transform var(--transition);
  }

  :global([dir='rtl']) .product-card__arrow {
    transform: scaleX(-1);
  }

  .product-card:hover .product-card__arrow,
  .product-card:focus-visible .product-card__arrow {
    transform: translateX(3px);
  }

  :global([dir='rtl']) .product-card:hover .product-card__arrow,
  :global([dir='rtl']) .product-card:focus-visible .product-card__arrow {
    transform: scaleX(-1) translateX(3px);
  }

  .products__ecosystems {
    margin-block-end: var(--space-6);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface-raised);
  }

  .products__ecosystems-copy {
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    line-height: var(--line-height-snug);
    max-width: 52ch;
  }

  .products__ecosystems-copy strong {
    display: block;
    color: var(--color-text);
    font-weight: var(--font-weight-semibold);
    margin-block-end: var(--space-1);
  }

  .products__ecosystems-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-accent);
    flex: none;
  }

  .products__ecosystems-link svg {
    inline-size: 15px;
    block-size: 15px;
  }

  :global([dir='rtl']) .products__ecosystems-link svg {
    transform: scaleX(-1);
  }

  .products__roadmap {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3) var(--space-4);
    padding: var(--space-4) var(--space-5);
    border: 1px dashed var(--color-border-strong);
    border-radius: var(--radius-lg);
    background: var(--color-surface-muted);
  }

  .roadmap-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    flex: none;
    padding-block: var(--space-1);
    padding-inline: var(--space-3);
    border-radius: var(--radius-full);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .roadmap-chip__dot {
    inline-size: 7px;
    block-size: 7px;
    border-radius: var(--radius-full);
    background: var(--color-spark);
  }

  .roadmap-text {
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    line-height: var(--line-height-snug);
  }

  .roadmap-text strong {
    color: var(--color-text);
    font-weight: var(--font-weight-semibold);
    margin-inline-end: var(--space-2);
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition: transform 0.6s var(--ease-spring), opacity 0.6s var(--ease-smooth);
    transition-delay: var(--reveal-delay, 0ms);
  }

  [data-reveal].is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      transform: none;
      transition: none;
    }
    .product-card,
    .product-card__arrow,
    .product-card__logo {
      transition: none;
    }
    .product-card:hover,
    .product-card:focus-visible {
      transform: none;
    }
  }

  @media (max-width: 560px) {
    .products__grid--products,
    .products__grid--services {
      grid-template-columns: 1fr;
    }
    .products__grid--products {
      grid-template-columns: 1fr;
    }
    .products__title {
      font-size: var(--text-2xl);
    }
  }
</style>

<script>
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const items = document.querySelectorAll<HTMLElement>('.products [data-reveal]');

  if (prefersReduced || !('IntersectionObserver' in window)) {
    items.forEach((el) => el.classList.add('is-revealed'));
  } else {
    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed');
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -10% 0px' },
    );
    items.forEach((el) => observer.observe(el));
  }
</script>
