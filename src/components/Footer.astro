---
/**
 * Fat footer (PRD §7.13): sitemap columns, contact, legal, social, VAT line.
 */
import { Image } from 'astro:assets';
import logo from '../assets/clicks-logo.png';
import {
  COMPANY_NAME, WHATSAPP, EMAIL_SAPIR, EMAIL_AMIT, VAT, BOOKING_URL,
  FOUNDER_LINKEDIN,
} from '../config';
import { localizedPath, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const content = {
  he: {
    tagline: 'מערכות הפעלה אסטרטגיות על monday.com',
    products: 'מוצרים',
    services: 'שירותים',
    sectors: 'מגזרים',
    company: 'החברה',
    contact: 'צרו קשר',
    whatsappContact: 'השארת פנייה בוואטסאפ',
    bookMeeting: 'קביעת פגישה',
    linkedinSapir: 'LinkedIn · ספיר',
    linkedinAmit: 'LinkedIn · עמית',
    accessibility: 'הצהרת נגישות',
    privacy: 'מדיניות פרטיות',
    rights: 'כל הזכויות שמורות',
    dealer: 'עוסק מורשה',
    productLinks: [
      ['Monday CMS', '/products/monday-cms'],
      ['Monday GIS', '/products/monday-gis'],
      ['Clicks deploy ready', '/products/clicks-deploy-ready'],
    ],
    serviceLinks: [
      ['FlowGram', '/services/flowgram'],
      ['Clicks TSM', '/services/clicks-tsm'],
      ['CRM Connections', '/services/crm-connections'],
      ['Clicks Solutions', '/services/clicks-solutions'],
    ],
    sectorLinks: [
      ['מגזר ציבורי', '/sectors/public-sector'],
      ['רשויות מקומיות', '/sectors/local-authorities'],
      ['אשכולות אזוריים', '/sectors/regional-clusters'],
      ['מלכ"רים', '/sectors/nonprofits'],
      ['מפעלים ו-low-tech', '/sectors/manufacturing'],
      ['הייטק', '/sectors/high-tech'],
    ],
    companyLinks: [
      ['אודות', '/about'],
      ['סיפורי לקוח', '/cases'],
    ],
  },
  en: {
    tagline: 'Bridging strategy, process and technology — at the point of impact',
    products: 'Products',
    services: 'Services',
    sectors: 'Sectors',
    company: 'Company',
    contact: 'Contact',
    whatsappContact: 'Message us on WhatsApp',
    bookMeeting: 'Schedule a meeting',
    linkedinSapir: 'LinkedIn · Sapir',
    linkedinAmit: 'LinkedIn · Amit',
    accessibility: 'Accessibility statement',
    privacy: 'Privacy policy',
    rights: 'All rights reserved',
    dealer: 'Licensed dealer',
    productLinks: [
      ['Monday CMS', '/products/monday-cms'],
      ['Monday GIS', '/products/monday-gis'],
      ['Clicks deploy ready', '/products/clicks-deploy-ready'],
    ],
    serviceLinks: [
      ['FlowGram', '/services/flowgram'],
      ['Clicks TSM', '/services/clicks-tsm'],
      ['CRM Connections', '/services/crm-connections'],
      ['Clicks Solutions', '/services/clicks-solutions'],
    ],
    sectorLinks: [
      ['Public sector', '/sectors/public-sector'],
      ['Local authorities', '/sectors/local-authorities'],
      ['Regional clusters', '/sectors/regional-clusters'],
      ['Nonprofits', '/sectors/nonprofits'],
      ['Manufacturing & low-tech', '/sectors/manufacturing'],
      ['High-tech', '/sectors/high-tech'],
    ],
    companyLinks: [
      ['About', '/about'],
      ['Cases', '/cases'],
    ],
  },
} as const;
const t = content[locale];
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__main">
      <div class="footer__brand">
        <a class="footer__brand-link" href={localizedPath('/', locale)} aria-label={COMPANY_NAME}>
          <Image
            src={logo}
            alt=""
            class="footer__logo"
            width={652}
            height={241}
            widths={[320, 480, 640]}
            loading="lazy"
            decoding="async"
          />
        </a>
        <p class="footer__tagline">{t.tagline}</p>
        <nav class="footer__brand-nav" aria-label={t.company}>
          <span class="footer__brand-nav-label">{t.company}</span>
          <ul>
            {t.companyLinks.map(([label, href]) => (
              <li><a href={localizedPath(href, locale)}>{label}</a></li>
            ))}
          </ul>
        </nav>
      </div>

      <nav class="footer__col" aria-label={t.products}>
        <h2 class="footer__heading">{t.products}</h2>
        <ul>
          {t.productLinks.map(([label, href]) => (
            <li><a href={localizedPath(href, locale)}>{label}</a></li>
          ))}
        </ul>
        <h2 class="footer__heading footer__heading--sub">{t.services}</h2>
        <ul>
          {t.serviceLinks.map(([label, href]) => (
            <li><a href={localizedPath(href, locale)}>{label}</a></li>
          ))}
        </ul>
      </nav>

      <nav class="footer__col" aria-label={t.sectors}>
        <h2 class="footer__heading">{t.sectors}</h2>
        <ul>
          {t.sectorLinks.map(([label, href]) => (
            <li><a href={localizedPath(href, locale)}>{label}</a></li>
          ))}
        </ul>
      </nav>

      <div class="footer__contact">
        <h2 class="footer__heading">{t.contact}</h2>
        <div class="footer__ctas">
          <a class="btn btn-secondary footer__cta" href={WHATSAPP} target="_blank" rel="noopener noreferrer">
            {t.whatsappContact}
          </a>
          <a class="btn btn-secondary footer__cta" href={BOOKING_URL} target="_blank" rel="noopener noreferrer">
            {t.bookMeeting}
          </a>
        </div>
        <ul class="footer__contact-links">
          <li><a href={`mailto:${EMAIL_SAPIR}`}>{EMAIL_SAPIR}</a></li>
          <li><a href={`mailto:${EMAIL_AMIT}`}>{EMAIL_AMIT}</a></li>
          <li>
            <a href={FOUNDER_LINKEDIN.sapir} target="_blank" rel="noopener noreferrer">
              {t.linkedinSapir}
            </a>
          </li>
          <li>
            <a href={FOUNDER_LINKEDIN.amit} target="_blank" rel="noopener noreferrer">
              {t.linkedinAmit}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer__bar">
      <p class="footer__legal">
        © {year} {COMPANY_NAME}. {t.rights}. · {t.dealer} {VAT}
      </p>
      <nav class="footer__legal-links" aria-label={locale === 'he' ? 'מסמכים משפטיים' : 'Legal'}>
        <a href={localizedPath('/accessibility', locale)}>{t.accessibility}</a>
        <a href={localizedPath('/privacy', locale)}>{t.privacy}</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-surface-muted);
    border-block-start: 1px solid var(--color-divider);
    padding-block: var(--space-10) var(--space-6);
    margin-block-start: var(--space-10);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .footer__main {
    display: grid;
    gap: var(--space-8) var(--space-7);
    align-items: start;
  }

  @media (min-width: 720px) and (max-width: 1023px) {
    .footer__main {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .footer__brand,
    .footer__contact {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1024px) {
    .footer__main {
      grid-template-columns: minmax(14rem, 1.35fr) minmax(0, 1fr) minmax(0, 1fr) minmax(11rem, 1.05fr);
      gap: var(--space-7) var(--space-8);
    }

    .footer__brand {
      grid-column: auto;
      grid-row: auto;
    }

    .footer__contact {
      grid-column: auto;
      grid-row: auto;
    }
  }

  .footer__brand-link {
    display: inline-block;
    line-height: 0;
    margin-block-end: var(--space-4);
    text-decoration: none;
  }

  .footer__logo {
    display: block;
    height: 3.5rem;
    width: auto;
    max-width: 20rem;
    object-fit: contain;
    object-position: start center;
  }

  @media (min-width: 768px) {
    .footer__logo {
      height: 4rem;
      max-width: 22rem;
    }
  }

  .footer__tagline {
    margin: 0 0 var(--space-5);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--line-height-relaxed);
    max-width: 32ch;
    text-wrap: pretty;
  }

  .footer__brand-nav {
    margin-block-start: var(--space-2);
  }

  .footer__brand-nav-label {
    display: block;
    margin-block-end: var(--space-3);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .footer__brand-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-5);
  }

  .footer__brand-nav a {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .footer__brand-nav a:hover {
    color: var(--color-accent);
  }

  .footer__heading {
    margin: 0 0 var(--space-4);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .footer__heading--sub {
    margin-block-start: var(--space-6);
  }

  .footer__col ul,
  .footer__contact-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer__col a,
  .footer__contact-links a {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: 1.45;
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer__col a:hover,
  .footer__contact-links a:hover {
    color: var(--color-text);
  }

  .footer__contact {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .footer__ctas {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-block-end: var(--space-5);
  }

  .footer__cta {
    width: 100%;
    justify-content: center;
    white-space: normal;
    text-align: center;
    line-height: 1.35;
    padding-block: var(--space-3);
    padding-inline: var(--space-4);
  }

  .footer__contact-links {
    padding-block-start: var(--space-4);
    border-block-start: 1px solid var(--color-border);
    gap: var(--space-3);
  }

  .footer__contact-links a {
    font-size: var(--text-xs);
  }

  .footer__bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4) var(--space-6);
    padding-block-start: var(--space-6);
    border-block-start: 1px solid var(--color-divider);
  }

  .footer__legal {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    line-height: 1.5;
    text-wrap: pretty;
  }

  .footer__legal-links {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
    margin: 0;
    padding: 0;
  }

  .footer__legal-links a {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .footer__legal-links a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 719px) {
    .footer__contact {
      padding: var(--space-5);
      background: var(--color-surface-raised);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
    }
  }
</style>
